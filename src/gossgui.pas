function tbasiccolors.xpaintcalc(xmustpaint:boolean):longint;
const//Supports enhanced shading
   _hsp=2;
   _vsp=2;
var
   s:tclientinfo;
   b:twinrect;
   hsp,vsp,int2,int1,xlaststyle,xlineheight,xlineheight2,dcount,xcount,xsetwidth,p,dx,dy:longint;
   xtightblocks,xonce:boolean;

   function xlink(zindex:longint):twinrect;
   var
      br,bc,tc,tw:longint;
      z:string;
      xtitle:boolean;
   begin

   //defaults
   result   :=nilrect;

   //check
   z      :=icaps[zindex];

   if (z='') then exit;

   xtitle :=(istys[zindex]=1);

   if xtitle and xtightblocks then exit;//don't draw titles when in xtightblocks mode

   //get
   z        :=#32+z+#32;
   tw       :=fast__textwidth('',z,s.Rfn);

   case xtitle of
   true:begin//title

      result:=area__make(s.ci.left,dy,s.ci.right,dy+xlineheight2-1);
      if xmustpaint then
         begin

         //init
         br:=low__aorb(vititle.disableborder,vititle.border,s.e);
         bc:=low__aorb(vititle.disable,vititle.background,s.e);
         tc:=low__aorb(vititle.disablefont,vititle.font,s.e);

         //color block
         ffillarea   ( result ,bc ,viround );
         foutlinearea( result ,br ,viround );

         //text
         ftext(bc,result,result.left+2,dy+((xlineheight2-s.fnH) div 2),tc,'',z,s.Rfb,true);

         end;

      end;
   else begin

      result:=area__make(dx,dy,dx+xsetwidth-1,dy+xlineheight-1);

      if xtightblocks then
         begin

         if ((s.ci.right-result.right)<xsetwidth) then result.right:=s.ci.right;//stretch to far right -> no right rounding gap
         //no: looks bad: if ((ci.bottom-result.bottom)<xlineheight) then result.bottom:=ci.bottom;//stretch to far bottom -> no bottom rounding gap

         end;

      if xmustpaint then
         begin

         //init
         br  :=s.border;
         bc  :=icols[zindex];
         //was: tc  :=int__invert2b(bc,true);
         tc  :=int__colorlabel(bc);//13sep2024

         case xtightblocks of
         true:begin                     //show the click

            ffillarea   ( result ,bc                                                   ,false );//color block
            foutlinearea( result ,low__aorb(bc,tc,oclicktouse and (zindex=idownindex)) ,false );

            end;
         else begin

            ffillarea   ( result ,bc ,viround );//color block
            foutlinearea( result ,br ,viround );

            if oshowcaps then ftext(bc,result,dx+((xsetwidth-tw) div 2),dy+((xlineheight-s.fnH) div 2),tc,'',z,s.Rfn,true);//text

            end;
         end;//case

         end;
      end;
   end;//case
   end;
begin
//defaults
result:=0;

try
//init
infovars(s);

//.xcount + xsetwidth
xtightblocks   :=otightblocks;
hsp            :=low__insint(_hsp*s.zoom,not xtightblocks);
vsp            :=low__insint(_vsp*s.zoom,not xtightblocks);
xcount         :=low__aorb(icount,itemsperline,itemsperline>=1);
xsetwidth      :=frcmin32( (s.ci.right-s.ci.left+1-((xcount+1)*hsp)) div frcmin32(xcount,1),1);

if xtightblocks then
   begin

   int1        :=0;

   for p:=0 to high(icaps) do if (icaps[p]<>'') and (istys[p]=0) then inc(int1);

   int2        :=int1 div xcount;
   if ((int2*xcount)<>int1) then inc(int2);

   xlineheight :=(s.ci.bottom-s.ci.top+1) div int2;
   xlineheight2:=xlineheight;

   end
else
   begin

   xlineheight :=lineheight;//color palette
   xlineheight2:=lineheight2;//title

   end;

xlaststyle:=-1;
xonce:=true;

//cls
if xmustpaint then ffillArea(s.cs,s.back,false);

//links
dx:=s.ci.left+hsp;
dy:=s.ci.top;
dcount:=0;

for p:=0 to high(icaps) do
begin

if (icaps[p]<>'') then
   begin

   if xonce and (istys[p]<>1) then inc(dy,vsp);
   inc(dcount);

   if (dcount>xcount) or ((istys[p]=1) and (xlaststyle=0)) or ((xlaststyle<>istys[p]) and (not xonce)) then
      begin

      dcount          :=1;
      dx              :=s.ci.left+hsp;

      inc(dy,low__aorb(xlineheight,xlineheight2,(xlaststyle=1))+vsp);

      if (istys[p]=1) and (xlaststyle<>1) then inc(dy,3);

      end;

   b                  :=xlink(p);

   if xmustpaint then irecs[p]:=b;

   inc(dx,xsetwidth+hsp);

   xlaststyle         :=istys[p];
   xonce              :=false;

   end
else
   begin

   if xmustpaint then irecs[p]:=nilrect;

   end;

end;//p

//frame
if xmustpaint then xframeSimple( s);

//return result
if (dy>=1) then result:=dy+xlineheight+vsp;

except;end;
end;

function tbasiccolors._onnotify(sender:tobject):boolean;
var
   int1,int2,p:longint;

   function xfinditem(s:tpoint;var xindex:longint):boolean;
   var
      p:longint;
   begin

   result   :=false;
   xindex   :=-1;

   for p:=0 to high(icaps) do if (icaps[p]<>'') and area__within2(irecs[p],s) then
      begin

      xindex:=p;
      result:=true;
      break;

      end;

   end;

   function xfinditem2(s:tpoint;var xindex:longint):boolean;
   var
      p:longint;
   begin

   result   :=false;
   xindex   :=-1;

   for p:=0 to high(icaps) do if (icaps[p]<>'') and (istys[p]=0) and area__within2(irecs[p],s) then
      begin

      xindex:=p;
      result:=true;
      break;

      end;

   end;

begin

//defaults
result      :=false;

try

//mouse down
if gui.mousedownstroke then
   begin

   result   :=true;
   xfinditem2(mousedownxy,idownindex);
   paintnow;

   end;

//mouse move
if gui.mousemoved and (not gui.mousedown) then
   begin

   result   :=true;
   if xfinditem(mousexy,p) then help2:=ihlps[p] else help2:='';

   end;

if gui.mousemoved and gui.mousedown then
   begin

   result   :=true;
   if opopcolor and (idownindex>=0) and (idownindex<=high(icaps)) and gui.mousedraggingout3(clientarea.left,clientarea.top,irecs[idownindex],true,true) then col[idownindex]:=low__capcolor(0,0,true);

   end;

//mouse up
if gui.mouseupstroke then
   begin

   result   :=true;

   //reset
   if (idownindex>=0) then
      begin

      int1            :=idownindex;
      idownindex      :=-1;

      if oclicktouse and (int1>=0) and (not gui.mousewasdraggingout) and assigned(foncolor) then
         begin

         foncolor(self,icols[int1]);

         end

      else if opopcolor and (int1>=0) and (not gui.mousewasdraggingout) then
         begin

         int2         :=col[int1];

         if gui.popcolor(int2) then col3[int1]:=int2;//25may2021, 25feb2021

         end;

      paintnow;

      end;

   end;

//external event override - 01mar2021
if assigned(fonnotify) then fonnotify(sender);

except;end;
end;


