if (xarea.right<xarea.left) or (xarea.bottom<xarea.top) then exit;
xarea:=area__clip( area__make(0,0,width-1,height-1) ,xarea );

//get
xfd__drawtohost( xarea );

//add area to proc paint list
xdrawtohost__addarea(xarea);

end;

