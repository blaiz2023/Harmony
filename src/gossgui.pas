procedure tsimpleint._onpaint(sender:tobject);
var
   s:tclientinfo;
   xtouch,xhighbar,xdownlabel,xenabled:boolean;
   xval,tw,vsp,xlineheight,hsp,p,int0,int1,int2,int3,int4,dy:longint;
   ta,ba,da,da2:twinrect;
   z:string;
   cur1:currency;
begin
try

//init
infovars(s);
xval        :=val;
xlineheight :=xrowheight;//05sep2025
vsp         :=vilineVsep1orLESS;//2 per line
hsp         :=2*s.zoom;
xtouch      :=vitouch;
xenabled    :=enabled;
xdownlabel  :=gui.mousedown and (ihoverstyle=vlabel);
xhighbar    :=(gui.mousedown and (idownstyle=vbar)) or (ihightimer>slowms64);

//cls
ffillArea(s.cs,s.back,false);

//label
z:=xfindlabel;
ilastlabel:=z;

if (z<>'') then
   begin
   tw:=fast__textwidth('',z,s.Rfn);

   case oalign of
   1   :ta.left:=s.ci.left+ (((s.ci.right-s.ci.left+1)-tw) div 2);//center
   2   :ta.left:=s.ci.right-tw-hsp;//right
   else ta.left:=s.ci.left+hsp;//left
   end;//case

   ta :=area__make(ta.left,s.ci.top+1,ta.left+tw-1,s.ci.top+1+xlineheight);
   da2:=area__make(s.ci.left,s.ci.top,s.ci.right,s.ci.top+1+s.fnH);

   //hover focus
   if xenabled and (ihoverstyle=vlabel) then ffillArea(da2,s.hover,s.r);

   //label
   ftext( s.back ,s.ci,ta.left+insint(s.zoom,xdownlabel),ta.top+insint(s.zoom,xdownlabel),s.font,'',z,s.Rfn,true);

   //click area
   ialabel:=da2;

   end
else ialabel:=nilarea;


//bar outer area
da.left    :=s.ci.left   + hsp;
da.right   :=s.ci.right  - hsp;
da.top     :=s.ci.bottom -1 - (xlineheight - (2*vsp));
da.bottom  :=s.ci.bottom -1 - vsp;


//bar-line
ba         :=da;
ba.top     :=ba.top+(ba.bottom-ba.top) div 2;
ba.bottom  :=ba.top+s.zoom;

if xenabled and ((ihoverstyle=vbar) or (idownstyle=vbar)) then
   begin
   dec(ba.top,s.zoom);
   inc(ba.bottom,s.zoom);
   end;

ffillArea(ba,s.line,false);

//.ball
int4:=scale__px1(10,2);//ball width
int0:=frcmin32(da.right-da.left+1-int4,1);
int1:=frcmin32(imax-imin,1);
int2:=xval-imin;
int3:=frcrange32(round(int0*(int2/int1)),0,int0);

da2.top     :=da.top;
da2.bottom  :=da.bottom;
da2.left    :=da.left+frcmin32(int3-1,0);
da2.right   :=da2.left+int4;
iaball      :=da2;

//.bar-line usage indicator
if (da2.left>ba.left) then ffillArea(area__make(ba.left,ba.top,da2.left,ba.bottom),low__aorb(s.line2,s.colhover,xhighbar),s.r);

if ((idownstyle<>vbar) and (ihoverstyle<>vbar)) or (not enabled) then
   begin
   inc(da2.top,2*s.zoom);
   dec(da2.bottom,2*s.zoom);
   end;

//.draw ball
ffillArea(da2,s.font,s.r);
if xhighbar then ffillArea(area__grow(da2,-3*s.zoom),s.colhover,s.r);

//click area
iabar:=da;

//frame
xframeSimple( s );

except;end;
end;

function tsimpleint.vfind(x:tpoint):longint;
begin
if      area__within2(ialabel,x) then result:=vlabel
else if area__within2(iabar,x)   then result:=vbar
else                                  result:=vnone;
end;

function tsimpleint._onnotify(sender:tobject):boolean;
var
   int1,int2:longint;
   xmustpaint:boolean;
begin
//defaults
result    :=false;
xmustpaint:=false;

try
//wheel
if (gui.wheel<>0) then
   begin
   if enabled then
      begin
      val:=val-gui.wheel;
      result:=true;//own the wheel
      end;
   end;

//key
if (gui.key<>aknone) then
   begin
   case gui.key of
   akhome:begin
      if enabled then val:=imin;
      result:=true;
      end;
   akend:begin
      if enabled then val:=imax;
      result:=true;
      end;
   akleft,akup:begin
      if enabled then val:=val-1;
      result:=true;
      end;
   akright,akdown:begin
      if enabled then val:=val+1;
      result:=true;
      end;
   akprev:begin
      if enabled then val:=val-1;
      result:=true;
      end;
   aknext:begin
      if enabled then val:=val+1;
      result:=true;
      end;
   end;//case
   end;

//mouse down
if gui.mousedownstroke then
   begin
   idownval        :=val;
   idownstyle      :=vfind(mousedownxy);
   idownball       :=iaball;
   icanmorelessonup:=true;
   if (idownstyle=vbar) then ihightimer:=slowms64+250;

   //paint
   xmustpaint:=true;
   end;

//mouse move
if gui.mousemoved then
   begin
   //.hover state
   ihoverstyle:=vfind(mousemovexy);

   if      (ihoverstyle=vlabel) then help:=strdefb(ohelplabel,'Default|Click for default value')
   else if (ihoverstyle=vbar)   then help:=strdefb(ohelpbar,'Value|Slide to change value')
   else                              help:='';

   if low__setint(ihoverref,ihoverstyle) then xmustpaint:=true;

   //.shift bar ball
   if gui.mousedown and gui.mousedraggingfine and (not gui.mousedownstroke) and (idownstyle=vbar) then
      begin
      icanmorelessonup:=false;
      int1:=mousexy.x-mousedownxy.x;
      int2:=round((int1/frcmin32(clientwidth,1))*(imax-imin+1));
      val:=idownval+int2;
      end;
   end;

//mouse up
if gui.mouseupstroke then
   begin
   if (idownstyle=vlabel) then xclicklabel;

   //click more/less
   if (idownstyle=vbar) and icanmorelessonup then xmoreless;

   //reset
   if (idownstyle<>vnone) then
      begin
      idownstyle:=vnone;
      xmustpaint:=true;
      end;
   end;

//external event override - 01mar2021
if assigned(fonnotify) then fonnotify(sender);

//paint
if xmustpaint then paintnow;
except;end;
end;

procedure tsimpleint.xmoreless;//06jun2025

   function vdir(vball:twinrect):longint;
   var
      vpad:longint;
   begin
   vpad:=3*vizoom;

   if not area__valid(vball)                  then result:=0
   else if (mousemovexy.x<(vball.left -vpad)) then result:=-1//down
   else if (mousemovexy.x>(vball.right+vpad)) then result:=+1//up
   else                                            result:=0;
   end;
begin

//.adjustment relative to ball position
if (vdir(idownball)=vdir(iaball)) then
   begin
   case vdir(idownball) of
   -1:val:=val-1;
   +1:val:=val+1;
   end;//case
   end;

end;

