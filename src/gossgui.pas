   begin
   ihoveref:=frcmin64(slowms64+1000,ihoveref);
   imustpaint:=true;
   end;

//timer250;
if (slowms64>=itimer250) then
   begin

   if low__setstr(ipaintref,bnc(ihoveref>=slowms64)) then imustpaint:=true;
   if low__setbol(iref,olarge) then
      begin
      imustpaint:=false;
      gui.fullalignpaint;
      end;

   //reset
   itimer250:=slowms64+250;
   end;

