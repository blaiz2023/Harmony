function tbasicsplash.xcontentarea:twinrect;
label
   redo;
var
   p,xlinecount,xsize,xgap,sw,sh,cw,ch,int1:longint;
   xname,xvalue:string;
begin

//defaults
result :=area__make(0,0,300,100);

try
//init
sw     :=frcmin32(gui.width,1);
sh     :=frcmin32(gui.height,1);

if xhavehead and xhead.visible         then dec(sh,xhead.getalignheight(0));
if xhavetoolbar2 and xtoolbar2.visible then dec(sh,xtoolbar2.getalignheight(0));
if xhavegrad2 and xgrad2.visible       then dec(sh,xgrad.getalignheight(0));

sh     :=frcmin32(sh,1);

xlinecount:=0;
for p:=0 to 9 do if splash__findvalue(p,xname,xvalue) then inc(xlinecount);

//find acceptable size
int1   :=2*findbordersize;
xgap   :=15;
xsize  :=scale__px1(520,1);//11dec2025

redo:
cw:=frcmin32(((xgap+xsize+xgap))-1+int1,1);
ch:=frcmin32(((xgap+round(xsize / 3.0)+xgap))-1+int1,1);

if (cw>sw) or (ch>sh) then
   begin
   if (xsize>96) then
      begin
      xsize:=frcmin32(xsize-8,32);
      xgap:=frcmin32(xgap-1,2);
      goto redo;
      end;
   end;

//set
inc(cw, low__len32(app__info('name')) * 5 );
inc(ch, xlinecount*vifontheight div 2);

result:=area__make(0,0,cw-1,ch-1);
if xhavehead and xhead.visible         then inc(result.bottom,xhead.getalignheight(0));
if xhavetoolbar2 and xtoolbar2.visible then inc(result.bottom,xtoolbar2.getalignheight(0));
if xhavegrad2 and xgrad2.visible       then inc(result.bottom,xgrad.getalignheight(0));

isize:=frcmin32(xsize,1);
igap:=frcmin32(xgap,1);
except;end;
end;

procedure tbasicsplash.onpaint__screen(sender:tobject);
label
   redo;

var
   s:tclientinfo;
   xsize,xgap,ncount,xlineheight,tgap,ih,dy,p:longint;
   ta,ia:twinrect;
   str1,str2:string;
   v:array[0..9] of string;

begin

//defaults
iscreen.infovars(s);

xgap        :=frcmin32( round32(igap*viscale) ,1 );
xsize       :=frcmin32(isize,1);

//title
ta.top      :=xgap;//round(s.ch*0.15);
ta.bottom   :=round(s.ch / 3.0);//was 2.5 - 14jul2025
ta.left     :=xgap;
ta.right    :=s.cw-xgap;

xmaketitle(ta.right-ta.left+1,ta.bottom-ta.top+1);
//was: iscreen.ldc3(ta,ta.left,ta.top,ta.right-ta.left+1,ta.bottom-ta.top+1,misarea(ititle32),ititle32,255,0,0,clnone,0,true,true);
iscreen.fdraw3(ititle32,misarea(ititle32),ta.left,ta.top,ta.right-ta.left+1,ta.bottom-ta.top+1,clnone,power_enabled,vifeather,false,false,true);

//information text
ia.left     :=ta.left+round32(2*viscale);
ia.right    :=s.cw-1;
ia.top      :=ta.bottom;
ia.bottom   :=s.ch-1-xgap;
ih          :=ia.bottom-ia.top+1;
tgap        :=15*s.zoom;

ncount:=0;
for p:=0 to high(v) do if splash__findvalue(p,str1,str2) then
   begin

   v[ncount]          :=str1+#9+str2;
   inc(ncount);

   end;

if (ncount>=1) then
   begin

   redo:

   xlineheight        :=round(s.fnH*1.25);

   //.center vertically in remaining window space
   dy:=ta.bottom+round32(2*viscale)+ ( s.ch-ta.bottom - (ncount*xlineheight) ) div 2;

   for p:=0 to (ncount-1) do
   begin

   iscreen.ftext( s.back ,ia ,ia.left ,dy ,s.font ,'L70;L500;' ,v[p] ,s.Rfn ,true );//28feb2026
   inc(dy,xlineheight);

   end;//p

   end;

end;

