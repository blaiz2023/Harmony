function sysback__maketileFromName(const d:tobject;const sv:string):boolean;
label
   skipend;
var
   da:twinrect;
   b:tbasicimage;
   r:tresslot;
   xPreviousSlot:pfastdraw;
   lp,slen,p,xbits,xw,xh:longint;
   pn,n,v:string;
   c24:tcolor24;
   v32,dw,dh,dh2,dbackcol,dcol1,dcol2,dcol3,dcol4,dpower255,dsplice100:longint;
   xbackFilled:boolean;

   function m(const xname:string):boolean;
   begin

   result:=strmatch(n,xname);

   end;

   function r100_255:longint;
   begin

   result:=frcrange32(100+random(156),0,255);

   end;

begin

//defaults
result                :=false;
r                     :=res_nil;
xPreviousSlot         :=nil;
b                     :=nil;

//check
if not misok82432(d,xbits,xw,xh) then exit;
if (sv='')                       then exit;

//init
pn          :='';//proc name
dw          :=1920;
dh          :=1080;
dh2         :=0;//not set
dbackcol    :=0;
dcol1       :=0;
dcol2       :=255;
dcol3       :=255;
dcol4       :=0;
dpower255   :=255;
dsplice100  :=50;
slen        :=low__len32(sv);
lp          :=1;
xbackFilled :=false;

//read values
for p:=1 to slen do if (sv[p-1+stroffset]=';') then
   begin

   //get
   v        :=strcopy1(sv,lp,p-lp);
   if (v<>'') then
      begin

      //get
      n     :=strcopy1(v,1,1);
      v     :=strcopy1(v,2,low__len32(v));
      v32   :=strint32(v);

      //set
      if      m('!') then pn           :=v
      else if m('w') then dw           :=v32
      else if m('h') then dh           :=v32
      else if m('j') then dh2          :=v32//height 2
      else if m('k') then dbackcol     :=v32
      else if m('a') then dcol1        :=v32
      else if m('b') then dcol2        :=v32
      else if m('c') then dcol3        :=v32
      else if m('d') then dcol4        :=v32
      else if m('p') then dpower255    :=v32
      else if m('s') then dsplice100   :=v32;

      end;

   //inc
   lp       :=p+1;

   end;

//check -> must have a proc name
if (pn='') then exit;


try


//range check ------------------------------------------------------------------

if (dh2<=0) then dh2:=dh;


//init -------------------------------------------------------------------------

fd__selStore(xPreviousSlot);
r           :=fd__new;//new + defaults
fd__select(r);

//size
if not missize( d ,dw ,dh ) then goto skipend;

da          :=misarea( d );

fd__setbuffer( fd_buffer ,d );

//background color
if (dbackcol>=0) then
   begin

   xbackFilled        :=true;
   fast__fillArea(da,da,dbackcol);

   end
else if (dbackcol=-1) then//transparent
   begin

   xbackFilled        :=true;
   mis__cls(d,0,0,0,0);

   end;


//make -------------------------------------------------------------------------

if (pn='gradient') then
   begin

   //cls unused area
   if (dh2<dh) and (not xbackFilled) then mis__cls(d,0,0,0,0);

   //draw
   da       :=area__make(da.left,0,da.right,frcmin32(dh2-1,0));
   fast__shadeArea3(da,da,dcol1,dcol2,dcol3,dcol4,dsplice100,dpower255,0,0,false);

   end
else if (pn='v-line') then
   begin

   //create line horizontally and then rotate and draw onto main image
   b        :=misimg24(dh,round32(100*viscale));
   fd__setbuffer( fd_buffer ,b );

   fast__shadeArea3(misarea(b),misarea(b),dcol1,dcol2,dcol3,dcol4,dsplice100,dpower255,0,0,false);

   //roate
   mis__rotate82432(b,-90);

   //draw
   fd__setbuffer( fd_buffer  ,d );
   fd__setbuffer( fd_buffer2 ,b );

   fd__setarea( fd_area  ,misarea(b));
   fd__setarea( fd_area2 ,misarea(b));

   fd__render( fd_drawRGB );

   end
else if (pn='random-color') then
   begin

   fast__fillArea(da,da,rgba0__int( r100_255 ,r100_255 ,r100_255 ) );

   end
else goto skipend;

//successful
result:=true;
skipend:

except;end;

//finalise
mis__nocells(d);//required

//previous slot
if (xPreviousSlot<>nil) then fd__selRestore(xPreviousSlot);

//free
res__del(r);
freeobj(@b);

end;

