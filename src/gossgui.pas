function clip__pasteimagefrom2(const d:tobject;const xaltsource:tobject;const xenhancedformats,xfit:boolean;xfitmaxW,xfitmaxH:longint):boolean;//29apr2025, 17mar2025, 14apr2021, 12apr2021
label
   skipend;
var
   a:tobject;
   aw,ah,xbits,xw,xh,ddw,ddh:longint;
begin
//defaults
result :=false;
a      :=nil;
ddw    :=1;
ddh    :=1;

//check
if zznil(d,2004)                                            then exit;
if not clip__canpasteimagefrom(xaltsource,xenhancedformats) then exit;

try
//range
xfitmaxW:=frcmin32(xfitmaxW,0);
xfitmaxH:=frcmin32(xfitmaxH,0);

//get
//.xaltsource -> a
if zzok(xaltsource,1022) then
   begin
   
   if not misok82432(xaltsource,xbits,xw,xh) then goto skipend;

   a:=misraw32(xw,xh);

   if (xw<>misw(a)) or (xh<>mish(a))                         then goto skipend;
   if mishasai(xaltsource) and (not misaicopy(xaltsource,a)) then goto skipend;

   if not mis__copyfast( maxarea ,area__make(0,0,xw-1,xh-1) ,0 ,0 ,xw ,xh ,xaltsource ,a ) then goto skipend;//fixed - 03apr2026, 14apr2021

   end
//.clipoard -> a
else
   begin

   a        :=misraw32(1,1);
   if not clip__pasteimage(a,xenhancedformats) then goto skipend;

   end;

//set
aw  :=misw(a);
ah  :=mish(a);
ddw :=aw;
ddh :=ah;

//.size
if xfit then
   begin
   //.stretch fit
   if (xfitmaxW=0) and (xfitmaxH=0) then
      begin
      ddw:=frcmin32(misw(d),1);
      ddh:=frcmin32(mish(d),1);
      end
   //.scale fit
   else if (xfitmaxW>=1) and (xfitmaxH>=1) then
      begin
      low__scaledown(xfitmaxW,xfitmaxH,aw,ah,ddw,ddh);
      end
   //.fixed width and variable height
   else if (xfitmaxW>=1) and (xfitmaxH=0) then
      begin
      ddw:=xfitmaxW;
      ddh:=frcmin32(round((xfitmaxW/frcmin32(aw,1))*ah),1);
      end
   //.fixed height and variable width
   else if (xfitmaxH>=1) and (xfitmaxW=0) then
      begin
      ddh:=xfitmaxH;
      ddw:=frcmin32(round((xfitmaxH/frcmin32(ah,1))*aw),1);
      end;
   end;

if (ddw<=0) or (ddh<=0) then goto skipend;
if ((ddw<>misw(d)) or (ddh<>mish(d))) and (not missize(d,ddw,ddh)) then goto skipend;

if not mis__copyfast( maxarea ,area__make(0,0,aw-1,ah-1) ,0 ,0 ,ddw ,ddh ,a ,d ) then goto skipend;//03apr2026

//Note: Any change in cellwidth/cellheight has to be modified
if mishasai(a) and mishasai(d) and (not misaicopy(a,d)) then goto skipend;

//successful
result:=true;
skipend:
except;end;

//free
freeobj(@a);

end;

