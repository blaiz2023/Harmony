procedure tbasicstatus._onpaint(sender:tobject);
const
   sp=3;
var
   s:tclientinfo;
   da,pa:twinrect;
   dcellwidth,xsepwidth,p2,px,xlast,dx,dy,p:longint;
   dpert:double;
   smark,sflash,dflash:boolean;
   dleft:array[0..high(icellleft)] of longint;
   dright:array[0..high(icellleft)] of longint;
   xflash:boolean;

   function xcellwidth(x:longint):longint;
   begin
   result:=icellwidth[x];
   if (result>=1) then result:=frcmin32(round(icellwidth[x]*s.zoom*vifontwidthratio),1);
   end;

   function dxalign(xalign:longint;x:string):longint;
   begin
   if (xalign=3) then xalign:=low__aorb(0,1,ocenter);

   case xalign of
   1:result:=frcmin32(((da.right-da.left+1)-fast__textwidth('',x,s.fn)) div 2,0);//center
   2:result:=frcmin32(da.right-1-fast__textwidth('',x,s.fn),0);//right
   else result:=0;//left
   end;//case

   end;
begin
try
//init
infovars(s);

//cls
ffillArea(s.cs,s.back,false);

xflash   :=(iflashcount>=1) and ilastflash;
xsepwidth:=low__aorb(1,2,s.bs>=1)*s.zoom;

//dleft
for p:=0 to high(dleft) do
begin
dleft[p] :=0;
dright[p]:=-1;
end;//p

//find last
for p:=high(icellwidth) downto 0 do
begin
xlast:=p;
if (icellwidth[p]>=1) then break;
end;//p

//text
dx:=s.bs+1+sp;
px:=s.bs;
dy:=(s.ch-s.fnH) div 2;

for p:=0 to high(icellwidth) do if (icellwidth[p]>=1) or (icelltext[0]<>'') or (icellpert[p]>0) or (icellmark[p]) then
   begin
   //init
   smark      :=icellmark[p];
   sflash     :=icellflash[p];
   dflash     :=sflash and xflash;
   dcellwidth :=xcellwidth(p);
   dpert      :=icellpert[p];
   da.left    :=dx;

   if ((p=0) and (dcellwidth<=0)) or (p=xlast) then da.right:=s.cw-1-s.bs else da.right:=frcmin32(dx+dcellwidth-1-sp,dx);

   da.right   :=frcmax32(da.right,s.cs.right-s.bs);
   da.top     :=s.bs;
   da.bottom  :=s.ch-1-s.bs;
   dleft[p]   :=da.left;
   dright[p]  :=da.right;

   //get
   //.progress bar
   if (dpert>0) then
      begin
      pa      :=da;
      pa.left :=px;
      pa.right:=frcrange32(pa.left+round((pa.right-pa.left)*(dpert/100)),px,da.right);

      //.progress color
      if (not sflash) or dflash then
         begin
         ffillArea(pa,s.hover2,false);
         end;

      //.text
      ftext(s.back,da,da.left+dxalign(icellalign[p],icelltext[p]),dy,s.font,'',icelltext[p],s.Rfn ,true);//flash support - 29dec2021

      end
   else if dflash or (smark and (not sflash)) then
      begin
      pa      :=da;
      pa.left :=px;

      //.background
      ffillArea(pa,s.hover,false);

      //.text
      ftext(s.back,da,da.left+dxalign(icellalign[p],icelltext[p]),dy,s.font,'',icelltext[p],s.Rfn ,true);//flash support - 29dec2021

      end
   else//normal
      begin

      ftext(s.back,da,da.left+dxalign(icellalign[p],icelltext[p]),dy,s.font,'',icelltext[p],s.Rfn ,true);

      end;

   //vertical dividers -> 2px wide
   px:=da.right;
   if (p<xlast) and (xsepwidth>=1) then
      begin
      for p2:=1 to xsepwidth do ffillArea(area__make(da.right+p2,s.bs,da.right+p2,s.ch-1-s.bs),s.sep,false);//26may2025
      px:=da.right+xsepwidth;
      end;

   //inc
   inc(dx,dcellwidth+xsepwidth);
   end;

//frame
if (s.bs>=1) then fframeSimple( s.cs ,s.bs ,s.border ,255 ,false ,s.roundFrame );

//set
for p:=0 to high(dleft) do
begin
icellleft[p] :=dleft[p];
icellright[p]:=dright[p];
end;//p

except;end;
end;

