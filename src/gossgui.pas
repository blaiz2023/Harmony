function tbasictea.setdata(xdata:tstr8):boolean;
var
   a:tbasicimage;
   b:tstr8;
   s:tclientinfo;
   e:string;

   procedure xclear;
   begin

   tep__clearpersistentdata( itepview );
   tep__clearpersistentdata( itepdata );
   tep__20 ( itepview ,[0] ,tep_temp20 ,df_mono ,df_color );
   tep__20 ( itepdata ,[0] ,tep_temp20 ,df_mono ,df_color );

   idata.clear;

   icanmakesolid      :=false;
   icanmaketransparent:=false;

   end;

begin

//defaults
a           :=nil;
b           :=nil;

//lock
str__lock(@xdata);

//init
a           :=misimg32(1,1);
b           :=str__new8;

//get
case (str__len32(@xdata)>=2) of
true:begin

   if mis__fromdata(a,@xdata,e) then
      begin

      //force image dimensions to that of a folder image
      tep__squareScaleImage( a ,tep_folderImageWH );

      //save in TEA format
      mis__todata(a,@idata,'tea',e);

      //store image in temp TEP slot
      tep__setpersistentdata( itepview ,@idata ,[0] );
      tep__setpersistentdata( itepdata ,@idata ,[0] );
      tep__20( itepview ,[0] ,tep_blank20 ,df_mono ,df_color );
      tep__20( itepdata ,[0] ,tep_blank20 ,df_mono ,df_color );

      //get data from slot -> unscaled for "itep=tepTEMP20_noscaling"
      tep__todata(itepdata,@idata,'tea');//for accurate "bytes" value

      end
   else xclear;

   end;

else xclear;

end;//case

//information
tep__todata(itepdata,@b,'tea');//for accurate "bytes" value

mis__fromdata(a,@b,e);

case (idata.len>=2) of
true:begin

   iteppaint          :=itepview;
   iinfocolors        :=miscountcolors( a );
   iinfoshades        :=mask__count( a );
   iinfotrans         :=mask__hastransparency32( a );

   end;
else begin

   iteppaint          :=tep__folderimageDefault20( ifolder );

   infovars( s );

   tep__copytoimage( a ,iteppaint ,s.font ,s.line ,clWhite ,clBlack );

   end;
end;//case

iinfocolors           :=miscountcolors( a );
iinfoshades           :=mask__count( a );
iinfotrans            :=mask__hastransparency32( a );

icanmaketransparent   :=(idata.len>=2) and (not iinfotrans);
icanmakesolid         :=(idata.len>=2) and iinfotrans;

//paint
imustpaint  :=true;

//free
freeobj(@a);
str__free(@b);
str__uaf(@xdata);

end;

