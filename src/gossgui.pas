procedure tbasicedit._onpaint(sender:tobject);//28nov2025
label
   skiptext;
var
   s:tclientinfo;
   pa,ta:twinrect;
   zw,ty,dlineheight,fn,fnH,shiftby,xpad0,xpad1,xpad2,xtep,xtep2,xtep2b,p,xw,xh,int1,int2,int3,tw,dx2,dx:longint;
   xmousedown,bol1,ashowcursor:boolean;
   xvalue,xcap,xtitle,z:string;
   xprogress:single;
begin
try

//init
infovars(s);

xtitle        :=ititle;
dlineheight   :=xlineheight;
xpad0         :=2*s.zoom;//left image margin AND cursor-padding
xpad1         :=5*s.zoom;
xpad2         :=5*s.zoom;
shiftby       :=2*s.zoom;//space to shift down and to right when "down" or "marked"

fn            :=s.Rfn;
fnH           :=s.fnH;

if (iscale<>1) then
   begin

   if (ifont=res_nil) then ifont:=res__newfont;

   fn         :=ifont;

   res__font( ifont ).setparams( s.info.fontname ,-frcmin32(round32(fnH*iscale),5) ,true ,false ,false );

   fnH        :=resfont__height(fn);

   end
else ifont:=res__del(ifont);//free font

ashowcursor   :=xshowcursor;
xmousedown    :=gui.mousedown and focused;//01aug2024: added "focused"
xprogress     :=iprogress;
xtep          :=itep;
xtep2         :=itep2;
xtep2b        :=itep2b;//14jun2022
xvalue        :=ivalue;
ty            :=s.ch-s.bs-xlineheight+((xlineheight-fnH) div 2);

//inputbased colorising - 20apr2025
if oinputcolorise.use then
   begin

   s.back:=inputcolorise__backcolor(oinputcolorise,0.1,low__len32(xvalue),s.back);

   end;

//.reveal password mode
if opassword and (xvalue<>'') then
   begin

   if (xtep2<>tepnone) then bol1:=(not ireveal) else bol1:=(not (gui.mousedown and gui.mouseleft and focused));

   if bol1 then
      begin

      for p:=0 to (low__len32(xvalue)-1) do xvalue[p+stroffset]:='*';

      end;

   end;

xcap          :=icaption;
ta            :=area__make(s.bs,s.bs,s.cw-1-s.bs,s.ch-1-s.bs);//start out using entire area, and gradually reduce to exact dimensions

//cls
ffillArea(s.cs,s.back,false);

//image - left
dx:=s.bs+xpad0;

if (xtep<>tepnone) then
   begin

   tep__info(xtep,xw,xh);

   //was: if (xprogress>=1) then lds2(area__make(ta.left,ta.top,dx+xw+xpad2,ta.bottom),s.hover,clnone,clnone,0,'h12',false);
   if (xprogress>=1) then fshadeArea(area__make(ta.left,ta.top,dx+xw+xpad2,ta.bottom),s.hover,s.hover,false);

   ftep(xtep,dx,((s.ch-xh) div 2),s.font,s.e);

   ibutarea1:=area__make(s.bs,0,xw+xpad2,s.ch-1);

   inc(dx,xw+xpad2);

   end
else ibutarea1:=area__make(0,0,-1,-1);

//image2 - right
if oborder2 then int3:=low__instouch(xpad1,vitouchsize20) else int3:=0;

dx2:=s.cw-1-frcmin32(s.bs,0)-low__insint(xpad1,int3<=0);

if (xtep2<>tepnone) then
   begin

   //Special Note: Force fit the button snug when zoom=1, else space it out from border when zoom>=2 - 19mar2021
   tep__info(xtep2,xw,xh);

   zw:=scale__px0(xw);

   dec(dx2,zw-1+(2*int3));

   ibutarea2:=area__make(
    dx2,
    s.ch-s.bs-xlineheight,
    dx2+int3+zw-1+int3+low__insint(1,s.zoom<=1),
    s.ch-1-s.bs+low__insint(1,s.zoom<=1)
    );

   if (int3>=1) and low__xyinarea(mousex,mousey,ibutarea2) then ffillArea(ibutarea2,s.hover,s.r);

   //note: dropdown list uses "orightbut_narrowfocus=false" - 09mar2025
   if orightbut_narrowfocus then bol1:=xmousedown and low__xyinarea(mousex,mousey,ibutarea2) else bol1:=xmousedown;

   ftep( low__aorb(xtep2,xtep2b,ireveal and (xtep2b<>tepNone)), ibutarea2.left+((ibutarea2.right-ibutarea2.left+1-xw) div 2)+low__insint(shiftby,bol1),low__insint(shiftby,bol1)+ibutarea2.top+((ibutarea2.bottom-ibutarea2.top+1-xh) div 2),s.font,s.e);

   dec(dx2,xpad2);

   end
else ibutarea2:=area__make(0,0,-1,-1);

//text init
ta.left       :=dx;
ta.right      :=dx2;
if (ta.right<=ta.left) then goto skiptext;

//progress bar
if (xprogress>=1) then
   begin

   pa                 :=ta;
   if (xtep=tepnone)  then pa.left:=s.bs;

   int1               :=low__aorb(ta.right,s.cw-1-s.bs,xtep2=tepnone);
   pa.right:=frcrange32(trunc((xprogress/100)*int1),ta.left,int1);
   //was: if (xprogress>=1) then lds2(pa,s.hover,clnone,clnone,0,'h12',false);
   if (xprogress>=1) then fshadeArea(pa,s.hover,s.hover,false);

   end;

//title
if (xtitle<>'') then
   begin

   z    :=xlang(xtitle);
   ftext(s.back,ta,ta.left,s.bs,s.font,'',z,fn ,true);

   end;

//optional background caption - 11dec2025
if (xvalue='') and (xcap<>'') then
   begin

   z    :=xlang(xcap);
   ftext(s.back,ta,ta.left,ty,int__splice24(0.5,s.font,s.back),'',z,fn ,true);//03mar2026

   end;

//value
int2    :=0;
tw      :=0;

if (xvalue<>'') then
   begin

   tw   :=fast__textwidth('',xvalue,fn);
   int1 :=(ta.right-ta.left)+1;

   if       ohardleft then int2:=0
   else if (tw>int1)  then int2:=-(tw-int1);

   ftext(s.back,ta,ta.left+int2,ty,s.font,'',xvalue,fn ,true);

   end;

//slim cursor => scale=0.5 (50%)
if ashowcursor then
   begin

   finvertCorrectedArea( area__make( ta.left+tw+int2, s.ch-s.bs-xlineheight+1+xpad0 , ta.left+tw+int2+font__lineThickness2( fn, 0.5 )-1 ,s.ch-1-s.bs-xpad0) ,false );

   end;

skiptext:

//frame - special note: fills in outside corner areas with "xback" -> requires when progress is >=1 as it is square and the control/frame may be round, thus the outside corner area must be filled with "xback" to erase and overlap from the square progress shading - 13apr2020
if (s.bs>=1) then fframeSimple( s.cs ,s.bs ,low__aorb(s.back,s.mustborder,oshowborder) ,255 ,false ,s.r );

except;end;
end;

function tbasicedit._onshortcut(sender:tobject):boolean;//01mar2022
var
   xcode2:string;
begin//store shortcut so we can transmitt it to our host form later (once we've closed the menu) - 02apr2020
//defaults
result:=false;

try
xcode2:='';
//get
case gui.key of
akctrlU:xcode2:='edit.undo';//19jun2022
akctrlT:xcode2:='edit.cuttxt';//01mar2022
akctrlC:xcode2:='edit.copytxt';//01mar2022
akctrlP:xcode2:='edit.paste';
akctrlD:if not opassword then xcode2:='edit.clear';
akctrlR:xcode2:='edit.upper';
akctrlL:xcode2:='edit.lower';
akctrlN:xcode2:='edit.name';
end;//case
//set
if (xcode2<>'') then
   begin
   result:=true;
   showmenuClick(self,'',100,xcode2,clnone);
   end;
except;end;
end;

function tbasicedit._onnotify(sender:tobject):boolean;
var
   a:tpoint;
begin
//not handled
result:=false;

try
//key
if (gui.key<>aknone) then
   begin
   result:=true;
   if enabled and (not oreadonly) then
      begin
      case gui.key of
      0..255:if xundoautofill(1) then value:=value+char(gui.key);
      aktab:if xundoautofill(1) then value:=value+#9;
      //was: akdelete:value:='';// BUT mum likes both delete keys to delete ONE char at a time rather than clear the entire line of text - 20mar2021
      akdelete,akback:begin
         if (gui.key=akdelete) and odel_clearstext then value:=''
         else if (ivalue<>'') and xundoautofill(2) then value:=strcopy1(value,1,low__len32(value)-1);
         end;
      akreturn:if assigned(fonreturn) then low__fireevent(self,fonreturn);
      end;//case
      end;
   end;
//mouse
if gui.mouseupstroke and enabled then
   begin
   a:=mousedownxy;
   if      low__ptinarea(a,ibutarea2) then
      begin
      if assigned(fonclick2) then gui.xfireevent(self,fonclick2)//supports closelock - 03apr2021
      else if opassword then
         begin
         ireveal:=not ireveal;
         xshowpass;
         end
      else if (ocmd2<>'') then showmenuClick(self,'',100,ocmd2,clnone);//19apr2025
      end
   else if low__ptinarea(a,ibutarea1) and assigned(fonclick1) then gui.xfireevent(self,fonclick1)//supports closelock - 03apr2021
   else if idropstatic then
      begin
      if assigned(fonclick2) then gui.xfireevent(self,fonclick2);//supports closelock - 03apr2021
      end
   //double click show/hide for password only - 24sep2022
   else if gui.mousedbclick and opassword then
      begin
      ireveal:=not ireveal;
      xshowpass;
      end;
   end;
//.up/down stroke
if gui.mousedownstroke or gui.mouseupstroke or gui.mousemoved then xcheckref;
if gui.mousedownstroke or gui.mousedown or gui.mouseupstroke then xnotidle;
//.help
if gui.mousemoved and (not gui.mousedown) then
   begin
   //get
   a:=mousemovexy;
   if low__ptinarea(a,ibutarea1) then help2:=ibuthelp
   else if low__ptinarea(a,ibutarea2) then help2:=ibuthelp2
   else help2:='';//revert back to "help"
   end;
//showmenu - 20mar2021
if mustshowmenu then
   begin
   showmenu;
   result:=true;
   end;
//external event override - 01mar2021
if assigned(fonnotify) then fonnotify(sender);


//paint the right button
if (gui.mousedownstroke or gui.mouseupstroke) and enabled then
   begin
   a:=mousedownxy;
   if low__ptinarea(a,ibutarea1) or low__ptinarea(a,ibutarea2) then paintnow;
   end;
except;end;
end;

procedure tbasicedit.xcheckref;
begin
if visible and low__setstr(iref,bnc(opassword)+pcrefsep+bnc(ireveal)+pcrefsep+bnc(opassword and gui.mousedownstroke and focused)+pcrefsep+bnc(opassword and gui.mouseupstroke)+pcrefsep+bnc(oborder2)+pcrefsep+bnc(oborder2 and low__ptinarea(mousemovexy,ibutarea2))+pcrefsep+bnc(xshowcursor)+pcrefsep+bnc(focused)+pcrefsep+bnc(mouseinside)+pcrefsep+bnc(visible)+pcrefsep+bnc(enabled)) then paintnow;
end;

function tbasicedit.xshowcursor:boolean;
begin
result:=enabled and (not oreadonly) and focused and ((iidleref>=slowms64) or iflash);
end;

procedure tbasicedit.xnotidle;
begin
iidleref:=slowms64+750;
end;


