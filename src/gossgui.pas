   begin
   for p:=0 to (winlist.count-1) do
   begin
   i:=winlist.list[p];
   if (i>=0) and (i<icorecount) and zzok(icore[i],7095) and (icore[i] is tbasicscroll) and (icore[i].winstyle=wmfullwin) and icore[i].visible then
      begin
      xwin:=icore[i] as tbasicscroll;
      result:=true;
      break;
