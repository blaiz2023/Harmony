   if (n='custom') then
      begin
      io__fromfile(low__platprgext('cur'),@a,e);
      xvars.d['_prgcur']:=a;
      end
   else xvars.value['_prgcur']:='';
   end;
except;end;

//free
freeobj(@a);

end;

