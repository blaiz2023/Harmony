function tbasicbwp._onshortcut(sender:tobject):boolean;//09dec2024: fixed ctrl+c block when readonly, 28aug2024: fixed F3/F4 block when oreadonly=true
begin

if enabled and focused and ( (gui.key=akF3) or (gui.key=akF4) or (gui.key=akCTRLC) or (not oreadonly) ) and (gui.key<>aknone) and icore.canshortcut(gui.key) then
   begin

   result:=true;//handled
   if (gui.key=akF3) or (gui.key=akF4) then sysfind_handler:=icore.findhandler;

   icore.keyboard2(gui.key);

   end

else result:=false;//not handled

end;

function tbasicbwp._onnotify(sender:tobject):boolean;
begin

//handled
result      :=true;//take control -> cancels system drag up/down and allows for screen color grab based dragging - 28jul2020

//wheel
if (gui.wheel<>0) then
   begin

   if enabled then
      begin

      case vsmooth of
      true:icore.vwheel(gui.wheel);//move Y row.pixels
      else vpos:=vpos-gui.wheel;
      end;//case

      end;

   xfaster;

   end;

//key
if (gui.key<>aknone) then
   begin

   if enabled and (gui.key<>aknone) and (gui.key<>akreturn) then icore.keyboard2(gui.key);

   xfaster;

   end;

//mouse
if gui.mousedownstroke then
   begin

   icore.mouse(mousex-imleft,mousey-imtop,true,gui.mouseright);

   xfaster;

   end
else if gui.mouseupstroke then
   begin

   icore.mouse(mousex-imleft,mousey-imtop,false,gui.mouseright);

   autoshowmenu;
   xfaster;

   end
else if gui.mousemoved then
   begin

   icore.mouse(mousex-imleft,mousey-imtop,gui.mousedown,gui.mouseright);

   if gui.mousedown then xfaster;

   end;

//external event override - 01mar2021
if assigned(fonnotify) then fonnotify(sender);

end;

