end;

procedure tbasicbwp.xwordcoretimer(xsyncnow:boolean);
var
   p:longint;
   bol1:boolean;
begin
try
//check
if ibuildingcontrol then exit;

//slow down checking when not visible to user -> check the "visibletohost" chain for this -> reduces number of calls made using "bnew" each second -  05jul2022
if not xsyncnow then
   begin

   if (islowdownref>slowms64) then exit else islowdownref:=slowms64+low__insint(500,not visibletohost);

   end;

//timer event - high speed
icore.hostsizing      :=gui.resizing;
icore.xtimer;

//v+h scrollbars
if ((slowms64>=itimersync) or (itimersync_fastcount>=1) or xsyncnow) then
   begin

   //check
   if (itimersync_fastcount>=1) then dec(itimersync_fastcount);

   //get
   if low__setstr(iref,bnc(orows)) then icore.mustpaint:=true;

   xsync;

   //reset
   itimersync:=slowms64+low__aorb(200,50,itimersync_fastcount>=1);//fastcount allows for a short but fast period of rapid repeat checking for important GUI changes, usually after a call to "ioset()" - 12mar2021

   end;

//paint event
if icore.canpaint and icore.mustpaint then
   begin

   icore.mustpaint:=false;
   paintnow;

   end;

//realtime word counter - 05feb2023
if olivewordcount and visible and ((inewpos>0) or low__setint(inewid,icore.dataid3)) then
   begin

   for p:=1 to 50000 do
   begin

   bol1:=icore.docsep(inewpos);

   if (bol1<>inewword) then
      begin

      inewword:=bol1;
      if not inewword then inc(inewcount);

      end;

   inc(inewpos);

   if (inewpos>=blen(icore.data)) then
      begin

      iwordcount      :=inewcount;
      inewpos         :=0;
      inewcount       :=0;
      inewword        :=false;
      break;

      end;

   end;//p

   end;

except;end;
end;

procedure tbasicbwp._onpaint(sender:tobject);
var
   s:tclientinfo;
   da:twinrect;
   pw,dleft,dright,lrpad,xrowcolor,int1,int2:longint;
begin
try

//check
if ibuildingcontrol or (not icore.paintlock(true)) then
   begin

   icore.mustpaint:=true;//retry later
   exit;

   end;

//init
xsync;
infovars(s);
lrpad                 :=s.zoom*10;

case orows of
true:xrowcolor        :=s.row;
else xrowcolor        :=clnone;
end;//case

dleft                 :=imleft+lrpad;
dright                :=imright+lrpad;
pw                    :=icore.pagewidth;

//inputbased colorising - 20apr2025
if oinputcolorise.use then s.back:=inputcolorise__backcolor(oinputcolorise,0.1,icore.data.len32-1,s.back);//-1 on len as there's always a trailing return code present

//cls
if ousepagecolor and (not icore.pageoverride2) and (icore.pagecolor<>clnone) then s.back:=icore.pagecolor;
ffillArea(s.cs,s.back,false);

//paint -> updated to handle wwsNone, wwsWindow and wwsPage - 12mar2021
case icore.wrapstyle of
wwsPage,wwsPage2:begin
   da.left:=iclientarea.left+s.bs+imleft;
   if (icore.pagewidth<icore.viewwidth) then inc(da.left,(icore.viewwidth-icore.pagewidth) div 2);//center the page when page is smaller than the viewing width
   end;
else da.left:=iclientarea.left+s.bs+imleft;
end;
da.right:=iv.clientarea.left-1-imright;//12mar2021
da.top:=iclientarea.top+s.bs+imtop;
if ih.visible then da.bottom:=ih.clientarea.top-1-imbottom else da.bottom:=iclientarea.bottom-s.bs-imbottom;


//render text
icore.render(da,ipaintarea,255,xrowcolor,s.back);

//draw page edges
if (icore.pagewidth<icore.viewwidth) and (icore.wrapstyle>=2) then
   begin

   int1:=int__dif24(s.back,-10);
   int2:=((s.cs.right-s.cs.left-iv.clientwidth)-pw) div 2;

   ffillArea(area__make(s.cs.left,s.cs.top,int2-dleft,s.cs.bottom),int1,false);
   ffillArea(area__make(s.cs.right-int2-iv.clientwidth+1,s.cs.top,s.cs.right-int2-iv.clientwidth+dright,s.cs.bottom),s.back,false);//patch vertical area with background - rows overwrite to far right of control - 04feb2023
   ffillArea(area__make(s.cs.right-int2-iv.clientwidth+dright,s.cs.top,iv.left-1,s.cs.bottom),int1,false);

   end;

//frame
if (s.bs>=1) then fframeSimple( s.cs ,s.bs ,int__dif24(s.border,oborderdiff),255 ,false ,s.r );

except;end;

//unlock paint
icore.paintlock(false);

end;

procedure tbasicbwp.xsync;
var//Note: Using "breuse()" proc greatly reduces the number of tstr8 objects needed to be created per second - 05jul2022
   int0,int1,int2,int3,int4:longint;
   xmousedown:boolean;
begin

//init
xmousedown  :=gui.mousedown;

//get
//.imustscrollto - delayed vertical scroll - 18dec2021
if ((imustscrollv_px>=0) or (imustscrollv>=0) or (imustscrollh>=0) or (imustpos>=0) or (imustpos2>=0)) and (not icore.wrapbusy) then
   begin

   int0:=imustscrollv_px; imustscrollv_px:=-1;
   int1:=imustscrollv;    imustscrollv:=-1;
   int2:=imustscrollh;    imustscrollh:=-1;
   int3:=imustpos;        imustpos:=-1;
   int4:=imustpos2;       imustpos2:=-1;

   //.cursorpos/2
   if (int3>=0) then icore.cursorpos:=int3;
   if (int4>=0) then icore.cursorpos2:=int4;

   //.force above cursor tasks to COMPLETE before issuing below h/vpos tasks - 07feb2023
   icore.xtimer;

   //.h/vpos
   if (int1>=0) then icore.vpos:=int1;
   if (int0>=0) then icore.vpos_px:=int0;//07feb2023
   if (int2>=0) then icore.hpos:=int2;

   end;

//.havefocus
//was: low__wordcore(icore,'havefocus',bn(focused or scrollbar1.focused or scrollbar2.focused));
icore.havefocus:=focused or iv.focused or ih.focused;

//.v
if icore.vhostsync then
   begin

   //int2:=low__wordcore2(icore,'vmax'+insstr('.px',vsmooth),nil);
   if icore.wrapdone then//or (int2>iv.max) then
      begin

      icore.vhostsync :=false;

      if vsmooth then
         begin
         int1         :=icore.vpos_px;
         int2         :=icore.vmax_px;
         end
      else
         begin
         int1         :=icore.vpos;
         int2         :=icore.vmax;
         end;

      iv.setparams2(int1,0,frcmin32(int2-low__insint(icore.viewheight-1,vsmooth),0),false);//prevent feedback loop to "_onpos => wordcore.set.vpos"

      end;

   end;

//.h
if (not xmousedown) and icore.hhostsync then
   begin

   icore.hhostsync    :=false;
   int1               :=icore.hpos;
   int2               :=icore.hmax;

   ih.setparams2(int1,0,int2,false);//prevent feedback loop to "_onpos => wordcore.set.hpos"

   end;

//.h.visible -> check rapidly -> hides control BEFORE screen is painting - 12mar2021
ih.visible:=icore.hshow;

//.line + column status
//   ilncount:=low__wordcore2(icore,'linecount','');
//   iln:=low__wordcore2(icore,'line','');
//   icol:=low__wordcore2(icore,'col','');

//wound scroller - 04oct2022
iv.oassistedscroll:=frcmin32(low__aorb(vifontsize,(clientheight div 5),vsmooth),1);//different scroll rates when vsmooth is ON or OFF

//.system colors
icore.pageselcolor        :=vinormal.highlight;
icore.pagefontselcolor    :=vinormal.fonthighlight;

//..override colors for pagecolor2 and pagefontcolor2 (overrides all font colors) when "pageoverride2=true"
//icore.pagecolorise2       :=false;//21jun2022
icore.pagecolor2          :=vinormal.background;
icore.pagefontcolor2      :=vinormal.font;//overrides internal font colors

end;

procedure tbasicbwp._onalign(sender:tobject);
var
   ci:twinrect;
   vwidth,hheight:longint;
begin

//get
//.v
vwidth                :=iv.getalignwidth(0);
ci                    :=clientinner;
iv.xsetclientarea(area__make(ci.right-vwidth-1,ci.top,ci.right,ci.bottom));

//.h -> size it always even when NOT visible -> paint system relies on it having valid coordinates at ALL times - 12mar2021
hheight               :=ih.getalignheight(0);
ih.xsetclientarea(area__make(ci.left,ci.bottom-(hheight-1),iv.clientarea.left-1,ci.bottom));

//.viewwidth
icore.viewwidth       :=frcmin32(ci.right-ci.left+1-vwidth-imleft-imright,0);

//.viewheight
icore.viewheight      :=frcmin32(ci.bottom-ci.top+1-hheight-imtop-imbottom,0);

//.update wordcore with current clientwidth immediately for BEST screen start - 29may2021
xwordcoretimer(true);

end;

