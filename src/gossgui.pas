function low__capcolor2(xpos,ypos:longint;const xfromcursor:boolean;const xfromGUIbuffer:tbasiccontrol;const xforceGUIbuffer:boolean):longint;//09sep2025
label
   skipend;
var
   a:twinbmp;
   b:tpoint;
   dx,dy:longint;
   c:tint4;
   c24:tcolor24;
   xfrombufferOK:boolean;
begin
//defaults
result        :=0;
xfrombufferOK :=false;
a             :=nil;

try

//init
if xfromcursor then
   begin
   low__getcursorpos(b);
   xpos:=b.x;
   ypos:=b.y;
   end;

//get
//.from buffer -> capture color directly from system.gui.buffer to avoid capturing the wrong color due to a system background image and/or system brightness setting - 24jul2024
if (xfromGUIbuffer<>nil) and (xfromGUIbuffer.gui<>nil) and (xforceGUIbuffer or xfromGUIbuffer.gui.paintedwithtile) then
   begin

