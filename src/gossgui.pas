irightmax            :=false;
irightgap            :=0;
irightminwidth       :=-50;
irightmaxwidth       :=350;//uses viScale to adapt dynamically to scaling changes - 03apr2026
iright               :=nil;

//.continue
oclsarea             :=true;//29mar2026
ofullalignpaint      :=false;
otopspace            :=0;
iscroll              :=xscroll;
istatic              :=false;
ofirstpos            :=min32;//off
osmallchange         :=10;
olargechange         :=50;
imainhelp            :=nil;//optional
ihead                :=nil;//optional
ihelp                :=nil;//optional
itoolbar             :=nil;//optional
itoolbar2            :=nil;//optional
itoolbar3            :=nil;//optional
igrad                :=nil;//optional
igrad2               :=nil;//optional
igrad3               :=nil;//optional
igrad4               :=nil;//optional
ihigh                :=nil;//optional
ihigh2               :=nil;//optional
istatus              :=nil;//optional
istatus2             :=nil;//optional
icols                :=nil;//optional
imenu                :=nil;//optional
inormal              :=true;
ibordersize          :=1;//30;//10;//no border -> can't repaint the controls in the clientarea without overwriting the border!!! - reconfirmed on 01aug2020
itimer100            :=slowms64;
itimer250            :=slowms64;
