if xstart then xindex:=cltopleft;
//get
xoutindex:=xindex;
case xindex of
cltopleft:xindex:=clWhite;
clWhite:xindex:=clBlack;
clBlack:xindex:=clRed;
clRed:xindex:=clLime;
clLime:xindex:=clBlue;
clBlue:xindex:=-1000;//custom
-1000:begin
   xindex:=-1001;//stop
   xoutcustomok:=true;
   end;
else result:=false;
end;
//set
if result then xoutlabel:=mistransLABEL(xoutindex,xcustom);
except;end;
end;

