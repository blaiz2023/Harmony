procedure tbackgroundmanager.xloadtile;//called by "preComputeCellForRender32()"
var
   a:tstr8;
   v,e:string;
   xbits:longint;

   procedure xnotile;
   begin

   missize(iuse_tile32,1,1);

   end;


   function xtileRef:string;

      procedure v(const n,x:string);
      begin

      result:=result+'|'+n+'_'+x;

      end;

      procedure v32(const n:string;const x:longint);
      begin

      v(n,intstr32(x));

      end;

   begin

   result:=sysback_name[iuse_itemindex];

   if sysback_remakeonScreen[iuse_itemindex] then
      begin

      v32( 'w' , monitors__screenwidth_auto );
      v32( 'h' , monitors__screenheight_auto );

      end;

   if sysback_remakeonScale[iuse_itemindex] then v32( 's' ,round32(viscale*1000) );

   if sysback_remakeonCrate[iuse_itemindex] then v32( 'a' ,icrateTriggerID );//just needs to be different each time to FORCE a remake

   end;

begin

//defaults
a:=nil;

try

//get -> supports static tiles (load once), dynamic tiles (remake on scale) and (remake always e.g. Random Color)
if low__setstr( iuse_tileref ,xtileRef ) then
   begin

   //.image handler - 13jan2026
   if (iuse_tile32=nil)   then iuse_tile32   :=misraw32(1,1);

   //.create tile from proc
   if (sysback_makename[iuse_itemindex]<>'') then
      begin

      if not sysback__makeTileFromName(iuse_tile32,sysback_makename[iuse_itemindex]) then xnotile;

      end

   //.load tile from "name" in "settings" folder
   else if (sysback_datafromfile[iuse_itemindex]<>'') then
      begin

      if not mis__fromfile(iuse_tile32,app__subfolder('settings')+sysback_datafromfile[iuse_itemindex],e) then xnotile;

      end

   //.load tile from data ptr
   else if (sysback_datafromptr[iuse_itemindex].count>=2) and (sysback_datafromptr[iuse_itemindex].bytes<>nil) then
      begin

      a:=str__new8;
      if not str__padd(@a,sysback_datafromptr[iuse_itemindex].bytes,sysback_datafromptr[iuse_itemindex].count) then xnotile;
      if not mis__fromdata(iuse_tile32,@a,e) then xnotile;

      end

   //.no tile to load
   else xnotile;

   //reset
   iuse_tileok     :=misok82432(iuse_tile32,xbits,iuse_tilew,iuse_tileh) and (xbits=32) and (iuse_tilew>=2) and (iuse_tileh>=2);
   iuse_cellcount  :=miscc(iuse_tile32);
   iuse_cellindex  :=0;
   iuse_scrollx    :=0;
   iuse_scrolly    :=0;
   iuse_wobblex    :=0;
   iuse_wobbley    :=0;
   iuse_wobblef    :=0;
   iuse_crate      :=0;

   rollid32(iuse_loadid);

   //.reset the cell timer BUT signal the timer NOT to increment to the next cell until the next timer cycle - 02mar2025, 26jul2024
   itimer:=min32;//reset

   end;

except;end;

//free
freeobj(@a);

end;

