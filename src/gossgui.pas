procedure tbasicbwp.makexxx(xformatlevel:longint;xuseonefont:longint;xviewurl:boolean);//31mar2025, 12jun2022
begin

//range
xformatlevel:=frcrange32(xformatlevel,0,2);//0=txt, 1=bwd, 2=bwp

//get
omenustyles:=(xformatlevel>=1);

icore.viewurl:=xviewurl;//31mar2025

case xuseonefont of
2:begin
   icore.onefontname:='$fontname2';//05feb2022
   icore.onefontsize:=1;//viFontsize2 - system size - 05feb2022
   end;
1:begin
   icore.onefontname:='$fontname';//05feb2022
   icore.onefontsize:=0;//viFontsize - system size - 05feb2022
   end;
else
   begin
   icore.onefontname:='';
   icore.onefontsize:=-1;
   end;
end;//case

icore.maxformatlevel:=xformatlevel;//plain text only - 12jun2022

end;

