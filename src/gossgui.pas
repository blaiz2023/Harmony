function tbasictea.xcmd(sender:tbasiccontrol;xstyle:string;xcode:longint;xcode2:string;xtepcolor:longint):boolean;
var
   v:string;
   v32:longint32;

   function m(const xname:string):boolean;
   begin

   result:=strmatch(xname,xcode2);

   end;

   function mv(const s:string):boolean;
   begin

   result:=strm(xcode2,s,v,v32);

   end;

begin

//defaults
result      :=true;//handled
v           :='';
v32         :=0;

//get
if      m('tea.menu')    then showmenu
else if m('tea.images')  then showmenu2('images')
else if mv('tea.image.') then usetep( v32 )
else if m('tea.default') then
   begin

   if (idata.len>=1) then
      begin

      xundoFill;
      setdata(nil);

      end;
      
   end
else if m('tea.maketransparent.tl') then makeimagetrans(true,0)
else if m('tea.maketransparent.bl') then makeimagetrans(true,1)
else if m('tea.makesolid')          then makeimagetrans(false,0)
else if m('tea.open')               then openimage
else if m('tea.save')               then saveimage
else if m('tea.undo')               then undo
else if m('tea.copy')               then copyimage
else if m('tea.paste')              then pasteimage
else
   begin

   result:=false;

   end;

end;


