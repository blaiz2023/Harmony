   a:tpoint;
   xcolor,r,i:longint;
begin
//handled
result:=true;

//find color
if gui.mouseupstroke then
   begin
   a:=mousemovexy;

   //find color from touch position
   if xinsideclientarea2(a.x,a.y) then
      begin

