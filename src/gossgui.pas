function tbwpbar._onnotify(sender:tobject):boolean;
var
   v,int1:longint;
   xmustpaint:boolean;
   str1:string;
   b:tobject;

   function b1:tbasicbwp;
   begin
   result:=(b as tbasicbwp);
   end;

begin

//defaults
result      :=true;//handled

try
xmustpaint:=false;

//down index
if gui.mousedown and (not gui.mousewasdown) then
   begin

   if low__setint(idownindex,findindex(mousemovexy.x,mousemovexy.y)) then xmustpaint:=true;

   end;

//hover index
if low__setint(ihoverindex,findindex(mousemovexy.x,mousemovexy.y)) then xmustpaint:=true;


//mouse up
if (not gui.mousedown) and gui.mousewasdown then
   begin
   //.act - button was clicked
   v        :=idownindex;
   b        :=findbox2;

   if      (v=isize) then showmenu2('size')
   else if (v=iwrap) then showmenu2('wrap')

   //bwp -----------------------------------------------------------------------
   else if (b is tbasicbwp) then
      begin

      //.style
      if      (v=inormal)       then b1.core.cmakenormal(false)
      else if (v=ibold)         then b1.core.cmakebold(false,not b1.core.cbold)
      else if (v=iitalic)       then b1.core.cmakeitalic(false,not b1.core.citalic)
      else if (v=iunderline)    then b1.core.cmakeunderline(false,not b1.core.cunderline)
      else if (v=istrikeout)    then b1.core.cmakestrikeout(false,not b1.core.cstrikeout)
      else if (v=ihighlight)    then b1.core.cmakehighlight(false)

      //.align
      else if (v=ileft)         then b1.core.cmakeleft(false)
      else if (v=icenter)       then b1.core.cmakecenter(false)
      else if (v=iright)        then b1.core.cmakeright(false)

      //.name
      else if (v=iname)         then
         begin

         str1:=b1.core.cname;
         if gui.popfont2(str1,true,true,true,true,self) then b1.core.cmakename(false,str1);

         end

      //.color
      else if (v=icolor) then
         begin

         int1:=b1.core.ccolor;
         if gui.popcolor(int1) then b1.core.cmakecolor(false,int1);

         end

      end;//if

   //.turn off button
   if low__setint(idownindex,-1) then xmustpaint:=true;

   end;

//external event override - 01mar2021
if assigned(fonnotify) then fonnotify(sender);

//xmustpaint
if xmustpaint then paintnow;

except;end;
end;

procedure tbwpbar._onpaint(sender:tobject);
var
   s:tclientinfo;
   p,xnextx,dh,fc:longint;
   b:tobject;
   xbold,xitalic,xunderline,xstrikeout:boolean;
   xfontsize,xcolor,xbgcolor,xalign:longint;
   xfontname:string;

   function b1:tbasicbwp;
   begin
   result:=(b as tbasicbwp);
   end;

   procedure xnextarea(xindex:longint);
   var
      dw:longint;
   begin

   //range
   dw:=frcmin32( round((s.ci.right-s.ci.left)*(frcrange32(ipert[xindex],1,100)/100)) ,1);

   //get
   iarea[xindex].top:=s.ci.top;
   iarea[xindex].bottom:=s.ci.bottom;
   iarea[xindex].left:=xnextx-dw+1;
   iarea[xindex].right:=xnextx;

   if (xindex=0) then iarea[xindex].left:=s.ci.left;//use all remaining space

   //inc
   dec(xnextx,dw);

   end;

   procedure xdraw(xindex:longint);
   var
      a:twinrect;
      c:string;
      dx,dy:longint;
      amark,ahover,adown:boolean;

      function na(var x:twinrect):boolean;//no area
      begin

      result :=true;//pass-thru
      x      :=area__nil;

      end;
      
   begin

   //check
   if (ipert[xindex]<=0)                  then exit;

   if (not ocancolor) and (xindex=icolor) and na(iarea[xindex]) then exit;
   if (not ocansize)  and (xindex=isize)  and na(iarea[xindex]) then exit;
   if (not ocanname)  and (xindex=iname)  and na(iarea[xindex]) then exit;

   if (not ocanalign) then
      begin

      if (xindex=ileft) or (xindex=icenter) or (xindex=iright) then exit;

      end;

   //get
   a        :=iarea[xindex];
   c        :=icap[xindex];

   if (xindex=iname) then
      begin

      if (b<>nil) then c:=xfontname else c:=viFontname;

      //nice label - 01mar2026
      if      strmatch(c,font__name1) then c:='System Font 1'
      else if strmatch(c,font__name2) then c:='System Font 2';

      end

   else if (xindex=isize) then
      begin

      if (b<>nil) then c:=intstr32(xfontsize) else c:=intstr32(viFontsize);

      end;

   adown    :=(xindex=idownindex);
   ahover   :=(xindex=ihoverindex);
   amark    :=false;

   if (b<>nil) then
      begin

      if      (xindex=inormal)      then amark:=(not xbold) and (not xitalic) and (not xunderline) and (not xstrikeout) and (xbgcolor=clnone)
      else if (xindex=ibold)        then amark:=xbold
      else if (xindex=iitalic)      then amark:=xitalic
