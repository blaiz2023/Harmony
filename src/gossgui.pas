function tbasictoolbar.xtepok2(xindex:longint):boolean;
begin
result:=((istyle=0) or (istyle=1)) and xok(xindex) and (piw[xindex]>=1) and (pih[xindex]>=1) and (itep[xindex]<>tepnone);
end;

