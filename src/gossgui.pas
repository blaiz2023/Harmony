end;

procedure tbasicmenu._onpaint(sender:tobject);//01dec2025, 15may2025, 20jul2024: soft back for title items
label
   redo;
const
   xpad=5;
   //color modes
   mnor=0;
   mdis=1;
   mhov=2;
var
   //infovars
   s:tclientinfo;
   ra:twinrect;
   cw,ch,findex:longint;
   xoff,yoff,drowpad,xfont,xback,xteptmp,ximagealign,xtep,xtepcolor,xtepcolor2,th,xmaxcutwidth,xmaxindentwidth,xmaxtepwidth,xmaxcapwidth,int1,int2,int3,vc,xcode,xshortcut,xindent,rh,p,dx,dy:longint;
   xtab,str1,str2,xcaption,xcaplabel,xhelp,xcode2:string;
   xenabled,xmarkrow,xflashON,xflash,xflashing,xrowbol,xrows,xtitle,xsep,xbold:boolean;
   xstyle:byte;
   xlist:tstr8;
   v:byte;

   function xrowarea:twinrect;
   begin

   result:=area__make(xoff+s.bs,yoff+dy+drowpad,xoff+cw-1-s.bs,yoff+dy+rh-1-drowpad);

   end;

begin
try

//defaults
xlist      :=nil;
xflashing  :=false;
xflashON   :=not sysflash;
drowpad    :=xrowpad;

//init
infovars(s);

if oinputcolorise.use then s.back:=inputcolorise__backcolor(oinputcolorise,0.1,0,s.back);

ch      :=s.ch;
cw      :=s.cw;
th      :=s.fnbH;//18apr2020
xtab    :=otab;//24feb2021
xstyle  :=ostyle;
xrows   :=virows and orows;
xrowbol :=false;
findex  :=s.Rfn;

cw      :=frcmin32(cw-low__insint(iv.clientwidth,iv.visible),1);//adjust down to exclude scrollbar width
rh      :=xrowheight;
dy      :=s.bs;
vc      :=vcount;//visible count

xlist   :=small__new8;//29aug2025

//.system widths -> for debug purposes, paint proc can adapt these values if too small OR if not set - 28mar2020
//note: for lists (with very long datasets, we can't calc imaxtepheight, so we have to assume viTepHeight20 - zoomed version )
xmaxindentwidth  :=frcmin32(imaxindentwidth,0);
xmaxtepwidth     :=frcmin32(imaxtepwidth,0)*s.zoom;
xmaxcapwidth     :=frcmin32(imaxcapwidth,0);
xmaxcutwidth     :=frcmin32(imaxcutwidth,0);
ximagealign      :=frcrange32(oimagealign,0,iaMax);

//cls
ffillArea(s.cs,s.back,false);

//get
p           :=frcrange32(ipos,0,frcmin32(icount-vc,0));//restrict scroll range

redo:

dx          :=s.bs+xpad;

if (p>=0) and (p<icount) and (dy<=(ch-1-s.bs)) and xgetitem2(p,xtab,xtep,xtepcolor,xtepcolor2,xcaption,xcaplabel,xhelp,xcode2,xcode,xshortcut,xindent,xflash,xenabled,xtitle,xsep,xbold) then
   begin

   //down
   case xenabled and (p=ihoverindex) and gui.mousedown and focused of
   true:xoff:=2*vilineVsep1orLESS;
   else xoff:=0;
   end;//case

   yoff     :=xoff;


   //init
   case xbold  of
   true:findex:=s.Rfb;
   else findex:=s.Rfn;//03oct2024
   end;

   if xflash then xflashing:=true;//tell system we need flashing support - 25mar2021

   xback      :=s.back;
   xfont      :=s.font;

   //ra
   ra         :=area__make(s.bs,dy,cw-1-s.bs,dy+rh-1);

   //show highlight/disabled etc

   //.title
   if xtitle then
      begin

      xback :=s.hover;
      findex:=s.Rfb;

      end

   //.disabled
   else if not xenabled then
      begin
      //nil
      end

   //.hover
   else if (xstyle=lsmenu) and (p=ihoverindex) then
      begin

      xback :=s.hover;

      end

   //.selection
   else if (xstyle>=lslist) and (p>=iselstart) and (p<(iselstart+iselcount)) then
      begin

      if (xstyle=lspanel) then xback:=s.row//very subtle highlight
      else
         begin

         xback :=s.colhover;
         xfont :=s.colfont;

         end;

      end

   //.no hover highlight
   else if (xstyle=lslist) and (p=ihoverindex) then//no hover highlight for lsmany - 07apr2020
      begin

      xback :=s.hover;

      end

   //.no hover highlight
   else if (xstyle=lspanel) and (p=ihoverindex) then
      begin

      xback :=s.row;//very subtle

      end

   //.items
   else
      begin

      if xrows and xrowbol  then xback:=s.row;

      end;


   //.altnerate row tracker
   if not xtitle then xrowbol:=not xrowbol;

   //.row background
   if (xback<>s.back) then ffillArea(xrowarea,xback,s.r);

   //.xmarkrow
   xmarkrow :=(ostyle=lsmany) and ((p=imanysel1) or (p=imanysel2)) and (imanysel1<>imanysel2) and (not xtitle);//for "select to here" visual markings - 28sep2022


   //indent --------------------------------------------------------------------

   //.scale
   if (xindent>=1) and (viscale>=1) then xindent:=scale__px0(xindent);

   //.largest
   if (xindent>xmaxindentwidth) then xmaxindentwidth:=xindent;
   inc(dx,xindent);


   //tep
   if (xtep<>tepnone) then
      begin
      //.auto system-zooms tep dimensions - 19aug2024, 03aug2024
      tep__info(xtep,int1,int2);//aw,ah

      case ximagealign of
      iaLeft    :xteptmp:=0;
      iaCenter  :xteptmp:=frcmin32((xmaxtepwidth-int1) div 2,0);
      iaRight   :xteptmp:=frcmin32(xmaxtepwidth-int1,0);
      else       xteptmp:=0;
      end;//case

      if (not xflash) or xflashON then
         begin

         //updated 19mar2026, 04dec2025, fixed 13apr2021, 26mar2021 //was "s.border" - 01dec2025
         ftep2(xtep,xoff+dx+xteptmp,yoff+dy+((rh-int2) div 2) ,xfont ,s.line,low__aorb(clwhite,xtepcolor,xtepcolor<>clnone) ,low__aorb(clblack,xtepcolor2,xtepcolor2<>clnone) ,255,xenabled);

         end;

      if (int1>xmaxtepwidth) then xmaxtepwidth:=int1;

      end;

   //caption
   if (not xtitle) or (xtep<>tepnone) then inc(dx,xmaxtepwidth+low__insint(xpad,xmaxtepwidth>=1));

   str1:=strdefb(xcaplabel,xcaption);
   if (str1<>'') then
      begin

      //.onumberfrom - use carefully - 20mar2022
      if (not xtitle) then
         begin

         if      (onumberfrom3>=0) and (p>=onumberfrom3) then str1:=k64(p-onumberfrom3+1)+'. '+str1
         else if (onumberfrom2>=0) and (p>=onumberfrom2) then str1:=k64(p-onumberfrom2+1)+'. '+str1
         else if (onumberfrom>=0)  and (p>=onumberfrom)  then str1:=k64(p-onumberfrom+1)+'. '+str1;

         end;

      ftext( s.back ,ra,xoff+dx,yoff+dy+((rh-th) div 2),xfont,xtab,str1,findex,xenabled);//21mar2026, 26feb2026
      int1:=fast__textwidth(xtab,str1,findex);
      if (not xtitle) and (int1>xmaxcapwidth) then xmaxcapwidth:=int1;

      end;

   //row marker - 04oct2024, 28sep2022
//was:   if xmarkrow then ffillArea(rect(cw-1-xbordersize-xpad-10,dy+2,cw-1-xbordersize-xpad-3,dy+rh-3),fcol,true);
   if xmarkrow then
      begin

      int3:=tepRight;
      tep__info(int3,int1,int2);//aw,ah

      //was: ldis2(ra,0,dy+((rh-int2) div 2),xfont,xfont,int3,(p=ihoverindex) and (xstyle=lsmenu) and xenabled and (not xtitle),not xenabled,s.r);
      ftep2(int3,0,dy+((rh-int2) div 2),xfont,xfont,xfont,xfont,255,xenabled);

      end;

   //hover and click item list
   xlist.addint4(p);
   xlist.addint4(dy);
   xlist.addint4(dy+rh);

   //shortcut - left align within it's column - 21mar2026, 13apr2020
   if (not xtitle) then
      begin

      inc(dx,xmaxcapwidth);

      if low__akstr(xshortcut,str2) and (str2<>'') then
         begin

         ftext( s.back ,area__make(xoff+dx,yoff+dy,cw-1-s.bs,dy+rh-1),cw-1-s.bs-xpad-largest32(xmaxcutwidth,fast__textwidth('',str2,findex)),dy+((rh-th) div 2),xfont,'',str2,findex,xenabled);

         end;

      end;

   //sep
   if xsep then ffillarea( area__make( ra.left ,ra.bottom ,ra.right ,ra.bottom) ,s.sep,s.r);//19may2025

   //next row
   inc(dy,rh);

   //loop
   inc(p);
   goto redo;

   end;

//draw border -> by default a menu has no border and instead relies on the underlying form for a border - 04apr2020
//Menu needs softening as it butts up against many other common controls -> this helps lighten the butt joins - 17mar2021
//was: if (s.bs>=1) then ldf(s.cs,s.border,int__dif24(s.back,-20),s.bs,nil,s.r);//26feb2022
xframeSimple( s );

//merge into existing list
if (xlist.count>=1) then
   begin

   if (xlist.count>ilist.count) then ilist.setlen(xlist.count);

   //was: for p:=0 to (xlist.count-1) do ilist.pbytes[p]:=xlist.pbytes[p];
   //faster - 22apr2022
   for p:=0 to (xlist.count32-1) do
   begin

   v:=xlist.pbytes[p];
   ilist.pbytes[p]:=v;

   end;//p

   end;

ilistcount:=xlist.count32 div 12;

//flash support
iwasflashing:=iflashing;
iflashing:=xflashing;

except;end;

//free
small__free8(@xlist);

end;

