function tbasicnav.xcmd(xcode:longint;xcode2:string;xtepcolor:longint):boolean;
label
   skipend;
var
   a:tbasiccontrol;
   b:tstr8;
   v32,p,xstyle,xtep:longint;
   xsize:comp;
   v,xname,xlabel,xfolder,str1:string;

   function m(const xname:string):boolean;
   begin

   result:=strmatch(xname,xcode2);

   end;

   function mv(const s:string):boolean;
   begin

   result:=strm(xcode2,s,v,v32);

   end;

begin

//defaults
result      :=true;//handled
v           :='';
v32         :=0;
b           :=nil;
xfolder     :=folder;

try

//get
if m('nav.home') then imustfolder:='home'
else if m('nav.refresh') then reload
else if m('nav.commonfolder') then imustfolder:=ocommonfolder
else if m('nav.prev') then prev
else if m('nav.next') then next
else if m('nav.fav') then popfav
else if m('nav.favadd') then
   begin

   if (xfavfolder<>'') then addfav(xfavfolder);//02jun2021

   end
else if m('nav.favedit') then
   begin

   if zzok(ifavcore,7266) then
      begin

      str1:=ifavcore.text;

      if gui.poptxt(str1,wwsNone,'Edit Favourites List','Folder Format|Type one full folder name per line including trailing slash - e.g. C:\Windows\ |*|Portable folders (folders on same drive as app) begin with "?:\"') then
         begin

         savefav(str__newaf8b(low__remdup2(str1,true,false,false)));
         loadfav;

         end;

      end;

   end
else if m('nav.up') then
   begin

   if (xfolder<>'') then
      begin

      str1:='home';

      if (low__len32(xfolder)>=2) then
         begin

         for p:=(low__len32(xfolder)-1) downto 1 do if (strcopy1x(xfolder,p,1)='\') or (strcopy1x(xfolder,p,1)='/') then
            begin

            str1:=strcopy1(xfolder,1,p);
            break;

            end;//p

         end;

      folder:=str1;

      end;

   end
else if m('nav.showfolder') then
   begin

   str1:=selectedfolder;
   if (str1<>'') then runlow(str1,'');

   end

else if mv('nav.editwithnotepad.') then//23mar2026, 18sep2025
   begin

   if (v<>'') then runlow('notepad',v);

   end
else if mv('nav.editwithpaint.') then//23mar2026, 18sep2025
   begin

   if (v<>'') then runlow('mspaint',v);

   end
else if mv('nav.print.') then//23mar2026, 18sep2025
   begin

   if (v<>'') then runlow('print',v);

   end
else if m('nav.copy') then clip__copytext(value)//30mar2022
else if m('nav.copyall') then
   begin

   b:=str__new8;

   if zzok(ilistcore,7284) then
      begin

      for p:=0 to max32 do
      begin

      if not nav__get(ilistcore,p,xstyle,xtep,xsize,xname,xlabel) then break;
      if (xstyle=nltFile) then b.sadd(ilistfolder+xname+rcode);

      end;//p

      clip__copytext(b.text);

      end;

   end
else if m('nav.selectall') then
   begin

   if (ilist<>nil) then ilist.setsel(0,ilist.count);

   end
else if m('nav.selectrange') then
   begin

   if (ilist<>nil) then ilist.selectrange;

   end
else if m('nav.selectstart') then
   begin

   if (ilist<>nil) then ilist.pos:=ilist.selstart-(ilist.vcount div 2);

   end
else if m('nav.selectend') then
   begin

   if (ilist<>nil) then ilist.pos:=ilist.selstart+frcmin32(ilist.selcount-1,0)-(ilist.vcount div 2);

   end
else if mv('nav.sort.') then
   begin

   sortstyle:=frcrange32(v32,0,nlMax);

   end
else if m('nav.newfolder') then
   begin

   if gui.popnewfolder(xfolder,str1) then folder:=str1;//14apr2021

   end
else if m('nav.folderimage') then
   begin

   str1:=selectedfolder;
   if (str1<>'') and io__driveexists(str1) and gui.popfolderimg(str1) then imustreload:=true;//12apr2021

   end
else if m('nav.openprompt') then
   begin

   str1:=value;

   if not io__fileexists(str1) then
      begin

      gui.poperror('','File not found "'+io__extractfilename(str1)+'"');
      goto skipend;

      end;

   //close the dlg window with the "open" button as clicked - 03mar2021
   if gui.xdlg(a) then
      begin

      a.ocode:=1;
      a.ocode2:='open';
      a.visible:=false;

      end;

   end
else if m('nav.saveprompt') then
   begin

   str1:=value;

   if io__fileexists(str1) then
      begin

      if not gui.popquery2('Replace existing file "'+io__extractfilename(str1)+'" ?','','Replace',false) then goto skipend;

      end;

   //close the dlg window with the "save" button as clicked - 03mar2021
   if gui.xdlg(a) then
      begin

      a.ocode:=1;
      a.ocode2:='save';
      a.visible:=false;

      end;

   end
else if m('nav.explore') then
   begin

   if (xfolder<>'') then runlow(xfolder,'');

   end
else if m('nav.preview') then preview:=not preview//22may2022
else if m('nav.showmenu') then
   begin

   if      zzok(ilist,7267) and ilist.ocanshowmenu then ilist.showmenu
   else if zzok(ifav,7268)  and ifav.ocanshowmenu  then ifav.showmenu;

   end
else result:=false;//not handled

skipend:
except;end;

//free
str__free(@b);

end;

