procedure tbasicnav.setfilterlist(x:string);//18sep2025
var//Note: expects a list of KNOWN extensions e.g. "bat;txt;bmp;tea" etc
   dcount,dindex,xlen,lp,p:longint;
   dlabel,dext,dmask:string;
   c:char;
begin
try

//init
dindex:=0;
dcount:=0;

//sort the list - 18sep2025
x:=filter__sort(x);

//get
xlen:=low__len32(x);
if (xlen>=1) then
   begin
   //init
   lp:=1;
   x:=x+fesep;
   xlen:=low__len32(x);
   //get
   for p:=1 to xlen do
   begin

   c:=x[p-1+stroffset];

   if (c=fesep) then
      begin

      //add
      if io__findext(strcopy1(x,lp,p-lp),dlabel,dext,dmask) then
         begin

         if (dcount>=high(fcap)) then break;

         fcap[dcount]:=dlabel;
         fext[dcount]:=dext;
         fmsk[dcount]:=dmask;
         ftep[dcount]:=tep__filetype20('.'+dext);

         inc(dcount);

         end;

      //reset
      lp:=p+1;

      end;

   end;//p

   end;//if

//set
fcount:=dcount;
findex:=frcrange32(dindex,0,frcmin32(dcount-1,0));
findex_tep;

except;end;
end;

