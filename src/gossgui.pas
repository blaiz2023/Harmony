function tbasicbwp.showmenuClick(sender:tobject;xstyle:string;xcode:longint;xcode2:string;xtepcolor:longint):boolean;
var
   e:string;
begin

//handled
result      :=true;

//information
if (xcode2='bwp.revert') then
   begin
   if zzok(irevertdata,7258) and gui.popquery2('Revert to original text and discard any changes?','','Revert',false) then iosetbwp(irevertdata);
   end

//.edit
else if (xcode2='bwp.undo')         then icore.undo
else if (xcode2='bwp.redo')         then icore.redo
else if (xcode2='bwp.cut')          then icore.cut
else if (xcode2='bwp.copy')         then icore.copy
else if (xcode2='bwp.copyall')      then icore.copyall
else if (xcode2='bwp.paste')        then icore.paste
else if (xcode2='bwp.pastereplace') then icore.pastereplace
else if (xcode2='bwp.selectall')    then icore.selectall
else if (xcode2='bwp.clearall')     then//no undo
   begin

   if zzok(irevertdata,7257) or undoenabled or gui.popquery('Clear all?') then icore.clearall;

   end
else if (xcode2='bwp.deleteall')     then//has undo
   begin

   if zzok(irevertdata,7257) or undoenabled or gui.popquery('Delete all?') then icore.deleteall;

   end

//.menu styles
else if (xcode2='bwp.normal')       then icore.cmakenormal(false)
else if (xcode2='bwp.bold')         then icore.cmakebold(false,not icore.cbold)
else if (xcode2='bwp.italic')       then icore.cmakeitalic(false,not icore.citalic)
else if (xcode2='bwp.underline')    then icore.cmakeunderline(false,not icore.cunderline)
else if (xcode2='bwp.strikeout')    then icore.cmakestrikeout(false,not icore.cstrikeout)
else if (xcode2='bwp.highlight')    then icore.cmakehighlight(false)
else if (xcode2='bwp.uppercase')    then icore.cmakeuppercase(false)
else if (xcode2='bwp.lowercase')    then icore.cmakelowercase(false)

//.menu align
else if (xcode2='bwp.left')         then icore.cmakeleft(false)
else if (xcode2='bwp.center')       then icore.cmakecenter(false)
else if (xcode2='bwp.right')        then icore.cmakeright(false)

//not handled
else result:=false;

end;

