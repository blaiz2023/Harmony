procedure tbasicsel._onpaint(sender:tobject);
const//Supports enhanced shading
   hsp=2;
var
   s:tclientinfo;
   xhoverindex,v,vsp,int1,int2,xtep,dcount,xlineheight,xlinecount,xcount,xsetwidth,xcapright,p,dx,dy:longint;
   xdown:boolean;
   z:string;

   function xlink(zindex:longint;zdraw:boolean):twinrect;
   const
      hsp=2;
   var
      int1,tw:longint;
      z:string;
      zdown,zhighlight:boolean;
   begin

   //defaults
   result     :=nilrect;

   //check
   z          :=icaps[zindex];
   if (z='') then exit;

   //get
   z          :=#32+z+#32;
   tw         :=fast__textwidth('',z,s.Rfn);
   int1       :=xlineheight-(2*vsp)-1;
   result     :=area__make(dx,dy+vsp,dx+xsetwidth-1,dy+int1);

   if zdraw then
      begin

      //.down
      zdown       :=xdown and (xhoverindex=zindex);

      //.highlight
      zhighlight  :=(zindex=v);

      //.cls
      if      zhighlight           then ffillArea(area__shift(result,insint(vsp,zdown),insint(vsp,zdown)),s.font,s.r)
      else if (xhoverindex=zindex) then ffillArea(area__shift(result,insint(vsp,zdown),insint(vsp,zdown)),s.hover,s.r);

      //.text
      ftext( low__aorb(s.back,s.font,zhighlight) ,result,dx+((xsetwidth-tw) div 2)+insint(s.zoom,zdown),dy+vsp+((int1-s.fnH) div 2)+insint(s.zoom,zdown),low__aorb(s.font,s.back,zhighlight),'',z,s.Rfn,true);

      end;

   end;

begin
try

//init
infovars(s);

//.xcount + xsetwidth
vsp                :=vilineVsep1orLESS;
xlineheight        :=xrowheight;//05sel2025
v                  :=ival;
xlinecount         :=linecount;
xcount             :=low__aorb(icount,itemsperline,itemsperline>=1);
xsetwidth          :=frcmin32( (s.ci.right-s.ci.left+1-((xcount+1)*hsp)) div frcmin32(xcount,1),1);
xtep               :=itep;
xhoverindex        :=ihoverindex;
xdown              :=gui.mousedown and focused;

//cls
ffillArea(s.cs,s.back,false);

//tep + caption
xcapright:=s.ci.left+5;

//.tep
if (xtep<>tepNone) and oshowtitle then
   begin

   tep__info(xtep,int1,int2);
   dy:=(xlineheight-int2) div 2;
   //was: ldis2(s.ci,xcapright,s.ci.top+dy,s.font,clnone,xtep,false,not s.e,s.r);
   ftep(xtep,xcapright,s.ci.top+dy,s.font,s.e);
   inc(xcapright,int1+(4*s.zoom));

   end;

//.caption
z:=caption;
if (z<>'') and oshowtitle then
   begin

   ftext( s.back ,s.ci,xcapright,s.ci.top+1,s.font,'',z,low__aorb(s.Rfn,s.Rfb,oboldhead),true);

   end;

//links
dx          :=s.ci.left+hsp;
dy          :=s.ci.bottom-(xlinecount*xlineheight)+vsp-1;
dcount      :=1;

for p:=0 to high(icaps) do
begin

if (icaps[p]<>'') then
   begin
   irecs[p]:=xlink(p,true);
   //was: irecs[p].top:=0;
   inc(dx,xsetwidth+hsp);
   inc(dcount);

   if (dcount>xcount) then
      begin
      dcount:=1;
      dx:=s.ci.left+hsp;
      inc(dy,xlineheight);
      end;

   end
else irecs[p]:=nilrect;

end;//p

//frame
xframeSimple( s );

except;end;
end;

function tbasicsel._onnotify(sender:tobject):boolean;
var
   p:longint;

   function xfinditem(s:tpoint;var xindex:longint):boolean;
   var
      p:longint;
   begin
   result:=false;
   xindex:=-1;
   for p:=0 to high(icaps) do if (icaps[p]<>'') and area__within2(irecs[p],s) then
      begin
      xindex:=p;
      result:=true;
      break;
      end;
   end;
begin
//defaults
result:=false;

try
//wheel
if (gui.wheel<>0) then
   begin
   if enabled then
      begin
      val:=val-gui.wheel;
      result:=true;//own the wheel!
      end;
   end;

//key
if (gui.key<>aknone) then
   begin
   case gui.key of
   akhome:begin
      if enabled then val:=0;
      result:=true;
      end;
   akend:begin
      if enabled then val:=imax;
      result:=true;
      end;
   akleft,akup:begin
      if enabled then val:=val-1;
      result:=true;
      end;
   akright,akdown:begin
      if enabled then val:=val+1;
      result:=true;
      end;
   akprev:begin
      if enabled then val:=val+1;
      result:=true;
      end;
   aknext:begin
      if enabled then val:=val+1;
      result:=true;
      end;
   end;//case
   end;

//mouse down
if gui.mousedownstroke then
   begin
   xfinditem(mousedownxy,idownindex);
   ihoverindex:=idownindex;
   paintnow;
   end;

//mouse move
if gui.mousemoved and (not gui.mousedown) then
   begin
   if xfinditem(mousexy,p) then help2:=ihlps[p] else help2:='';
   if low__setint(ihoverindex,p) then paintnow;
   end;

//mouse up
if gui.mouseupstroke then
   begin
   if (idownindex>=0) and (idownindex<=high(icaps)) then
      begin
      iwasselected:=(val=idownindex);
      val:=idownindex;
      end
   else iwasselected:=true;//use with "fonclick" to know if current item was previously selected or not - 26mar2022
   //reset
   if (idownindex>=0) then
      begin
      idownindex:=-1;
      paintnow;
      if ovalueclick then xonvalue;//29aug2021
      if assigned(fonclick) then fonclick(self);//07mar2022
      end;
   end;

//external event override - 01mar2021
if assigned(fonnotify) then fonnotify(sender);
except;end;
end;

