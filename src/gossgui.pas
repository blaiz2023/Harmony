function tbasicscrollbar._onnotify(sender:tobject):boolean;
var
   int1,dx,dy:longint;
begin

//defaults
result     :=ofullhandling;//not handled

try

//wheel
if ofullhandling and (gui.wheel<>0) then
   begin

   result:=true;//12dec2025

   if enabled then
      begin

      pos:=pos-(gui.wheel*owheelchange);
      xwound_wheel(gui.wheel*70);

      end;

   end;

//key
if ofullhandling and (gui.key<>aknone) then
   begin
   case gui.key of
   akhome:begin
      if enabled then pos:=imin;
      result:=true;
      end;
   akend:begin
      if enabled then pos:=imax;
      result:=true;
      end;
   akleft,akup:begin
      if enabled then pos:=pos+xmoveval(-1);
      result:=true;
      end;
   akright,akdown:begin
      if enabled then pos:=pos+xmoveval(1);
      result:=true;
      end;
   akprev:begin
      if enabled then pos:=pos+xmoveval(-olargechange);
      result:=true;
      end;
   aknext:begin
      if enabled then pos:=pos+xmoveval(olargechange);
      result:=true;
      end;
   end;//case
   end;

//mousedownstroke
if gui.mousedownstroke then
   begin

   idowntime64  :=slowms64+500;
   idownpos     :=pos;
   dx           :=mousex;
   dy           :=mousey;
   idragbutdown :=low__xyinarea(dx,dy,idragbut);

   if low__xyinarea(dx,dy,idragzone) then idownbutindex:=2//drag
   else                                   idownbutindex:=-1;//off

   end;

//mouse down
if gui.mousedown then
   begin
   result:=true;
   end;

//mouse move
if gui.mousedown and gui.mousemoved and (not gui.mousedownstroke) then
   begin

   result:=true;

   if enabled and (iscrollscope>=1) and (idownbutindex=2) and gui.mouseleft then
      begin

      if overtical then int1:=gui.mousemovexy.y-gui.mousedownxy.y else int1:=gui.mousemovexy.x-gui.mousedownxy.x;
      pos:=round(idownpos+((int1)*iscrollscope));//normal

      end;

   end;

//mouse up - wound support - 04oct2022
if gui.mouseupstroke and gui.mousedragging and gui.mouseleft then xwound_mousevert3(3000,true,true,overtical);

//mouse up
if gui.mouseupstroke then
   begin

   result        :=true;
   idowntime64   :=0;
   idownbutindex :=-1;//off

   end;

//external event override - 01mar2021
if assigned(fonnotify) then fonnotify(sender);
except;end;
end;

procedure tbasicscrollbar._onpaint(sender:tobject);
label
   dovertical,dohorizontal,done;
const
   xmindrag=24;
var
   s:tclientinfo;
   dw,dh,pad1,p,int1,int2,int3,int4,int5,xmin,xmax:longint;
   xhoverok,xvertical:boolean;

   function xsmaller(x:twinrect;w,h,xminimalsize:boolean):twinrect;
   var
      v:longint;
   begin
   result:=x;

   //.width
   if w then
      begin

      case xminimalsize of
      true:v:=frcmin32( trunc( (x.right-x.left+1) * 0.3 ) ,2);
      else v:=frcmin32( (result.right-result.left+1) div 4 ,2);
      end;//case

      result.left :=frcrange32(result.left+v,result.left,result.right);
      result.right:=frcrange32(result.right-v,result.left,result.right);

      end;

   //.height
   if h then
      begin

      case xminimalsize of
      true:v:=frcmin32( trunc( (result.bottom-result.top+1) * 0.3 ) ,2);
      else v:=frcmin32( (result.bottom-result.top+1) div 4 ,2);
      end;//case

      result.top   :=frcrange32(result.top+v,result.top,result.bottom);
      result.bottom:=frcrange32(result.bottom-v,result.top,result.bottom);

      end;

   end;
begin
//init
infovars(s);
pad1      :=5*s.zoom;
xmin      :=imin;
xmax      :=imax;
s.e       :=s.e and (xmax>xmin);//adjust value
xvertical :=overtical;
dw        :=(s.cs.right-s.cs.left+1)-(2*s.bs);
dh        :=(s.cs.bottom-s.cs.top+1)-(2*s.bs);
xhoverok  :=s.e and (gui.hoverindex=icoreindex);

//cls
ffillArea(s.cs,s.back,false);

//decide
if xvertical then goto dovertical else goto dohorizontal;

//-- vertical ------------------------------------------------------------------
dovertical:

idragzone :=area__make(0,1,s.cw-1,s.ch-1);//11oct2020
int4      :=frcmin32(imax-imin+1,1);//count
int1      :=frcmin32(idragzone.bottom-idragzone.top+1,0);
int2      :=frcmin32(int1-int4,low__instouch(xmindrag,vitouchsize20));
int3      :=frcmin32(int1-int2,0);
int5      :=frcmin32(int1-int2,0);

if (int5<=0) then iscrollscope:=0 else iscrollscope:=int4/int5;

if (int3>=1) then
   begin
   p:=round(((pos-imin)/int4)*int3);
   idragbut:=area__make(idragzone.left,idragzone.top+p,idragzone.right,idragzone.top+int2-1+p);

   if (imax<>imin) then
      begin

      ffillarea( xsmaller(idragbut,true,false,not xhoverok),low__aorb(s.hover,s.hover2,xhoverok),s.r );//28mar2026

      end;

   end
else idragbut:=area__make(0,0,-1,-1);

goto done;

//-- horizontal ----------------------------------------------------------------
dohorizontal:

idragzone :=area__make(1,0,s.cw-1,s.ch-1);//17mar2021, 11oct2020
int4      :=frcmin32(imax-imin+1,1);//count
int1      :=frcmin32(idragzone.right-idragzone.left+1,0);
int2      :=frcmin32(int1-int4,low__instouch(xmindrag,vitouchsize20));
int3      :=frcmin32(int1-int2,0);
int5      :=frcmin32(int1-int2,0);

if (int5<=0) then iscrollscope:=0 else iscrollscope:=int4/int5;

if (int3>=1) then
   begin
   p:=round(((pos-imin)/int4)*int3);
   idragbut:=area__make(idragzone.left+p,idragzone.top,idragzone.left+int2-1+p,idragzone.bottom);

   if (imax<>imin) then
      begin

      ffillArea( xsmaller(idragbut,false,true,not xhoverok),low__aorb(s.hover,s.hover2,xhoverok),s.r );//13sep2025

      end;

   end
else idragbut:=area__make(0,0,-1,-1);

goto done;

//-- done ----------------------------------------------------------------------
done:

end;

