procedure tbasictea._onpaint(sender:tobject);
const
   tcount=6;

var
   s:tclientinfo;
   rw,rh,aw,ah,dtep,int1,tmaxw,p,x1,x2,dx,dy,vw,vh:longint;
   da:twinrect;
   z,zval:string;

   function xinfo(x:longint;xval:boolean):string;
   begin

   result:='';

   case x of
   0:if xval then result:=low__aorbstr('Default ( Built-In )','Custom ('+tep__folderimageFilename(' ')+' )',idata.len>=2) else result:='Source';
   1:begin

      if xval then
         begin

         if (rw<=0) and (rh<=0) then result:=strdefb(odefaultmsg,'( Not in use )') else result:=k64(rw)+'w x '+k64(rh)+'h';

         end
      else result:='Dimensions';

      end;
   2:if xval then result:=low__aorbstr('-',low__b(idata.len32,true),idata.len32>=1) else result:='Size';
   3:if xval then result:=low__aorbstr('No','Yes',iinfotrans) else result:='Transparent';
   4:if xval then result:=k64(iinfocolors) else result:='Colors';
   5:if xval then result:=k64(iinfoshades) else result:='Shades';
   end;//case

   end;
begin
try


//init
infovars(s);

dtep        :=iteppaint;
aw          :=tep__width ( dtep );
ah          :=tep__height( dtep );
rw          :=tep__rootwidth ( dtep );
rh          :=tep__rootheight( dtep );
dx          :=scale__px1(20,2);
dy          :=s.ci.top;
vw          :=scale__px1(ivieww,1);
vh          :=scale__px1(iviewh,1);


//cls
ffillArea(s.cs,s.back,false);


//image
dy             :=(s.ch-vh) div 2;
da             :=area__make(dx,dy,dx+vw-1,dy+vh-1);

ftep( dtep ,da.left+((vw-aw) div 2) ,da.top+((vH-ah) div 2) ,s.font ,true );

foutlinearea(area__grow(da,1),s.line,false);


//information (5x lines)
inc(dx,vw + scale__px0(30) );
dy             :=(s.ch-(tcount*s.fnH)) div 2;

for p:=0 to pred(tcount) do
begin

ftext(s.back,s.ci,dx,dy,s.font,tbL100_L500,xinfo(p,false)+#9+xinfo(p,true),s.Rfn,true);
inc(dy,s.fnH);

end;//p


//frame
xframeSimple( s );

except;end;
end;

