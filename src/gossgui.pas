if ((a.right-a.left+1)>gui.width) then
   begin
   a.left:=0;
   a.right:=gui.width-1;
   result:=true;
   end;
if ((a.bottom-a.top+1)>gui.height) then
   begin
   a.top:=0;
   a.bottom:=gui.height-1;
   result:=true;
   end;
if result then xsetclientarea(a);
except;end;
end;

