if ((slowms64-debug_msstartave)>=1000) then
   begin

   debug_mstimeavefast :=div64(debug_mstimetotal2, frcmin64(debug_mstimecount2,1) );

   //reset
   debug_mstimetotal2  :=0;
   debug_mstimecount2  :=0;
   debug_msstartave    :=0;

   end;

   end;

