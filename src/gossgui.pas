procedure tbasicsystem.hint__format;//09may2025: single "*" on a line for blank line, 21apr2025, 09jan2025, 03jan2025
var
   xmaxwidth,xlinelimit:longint;
   xhint:string;

   procedure ladd(xline:string);
   var
      xlen,lp,p:longint;
      c:char;
      dline,v:string;
   begin
   //init
   if (xline='') then exit else xlen:=low__len32(xline);

   //get
   dline:='';
   lp:=1;

   for p:=1 to xlen do
   begin
   c:=xline[p-1+stroffset];

   if (c=#32) or (p=xlen) then
      begin
      v:=strcopy1(xline,lp,p-lp+1);
      lp:=p+1;

      if (v<>'') and ( (low__len32(dline)+low__len32(v)) > xlinelimit ) then
         begin
         ihintlines.value[ihintlines.count]:=dline;
         dline:=v;
         end
      else dline:=dline+v;
      end;

   end;//p

   //finalise
   if (dline<>'') then ihintlines.value[ihintlines.count]:=dline;
   end;

   procedure lparse;//parse into lines with white space stripped from beginning and end of each line
   var
      xlen,xlinecount,p,lp:longint;
      v:string;
      xonce:boolean;
   begin
   xlen:=low__len32(xhint);
   xonce:=true;
   xlinecount:=0;
   lp:=1;

   for p:=1 to xlen do if (xhint[p-1+stroffset]='|') then
      begin
      inc(xlinecount);
      if (xlinecount>=2) then break;
      end;

   for p:=1 to xlen do if (xhint[p-1+stroffset]='|') then
      begin
      v:=stripwhitespace_lt(strcopy1(xhint,lp,p-lp));
      if (v<>'') then
         begin
         //add line to hint list
         ladd(v);

         //calc how many lines the title takes up - it may be wrapped over multiple lines - 09jan2025: fixed title count wrap
         if xonce and (xlinecount>=2) then
            begin
            xonce:=false;
            if (v<>'') and hint__cantitle(v) then ihinttitle_linecount:=ihintlines.count;
            end;
         end;

      lp:=p+1;
      end;//p
   end;
begin
try
//check
if not vihint then exit;

//init
ihinttitle_linecount:=0;

if (ihintTimeout=-2)                      then ihintTimeout:=-1 else ihintTimeout:=0;
if (ihintlines<>nil)                      then ihintlines.clear;
if (low__len32(ihint)<=4) or (not vihint) then exit;
if (ihintlines=nil)                       then ihintlines:=tdynamicstring.create;

xhint:=strcopy1(ihint,5,low__len32(ihint))+'|';

//max-width tailored to current screen width
xmaxwidth :=frcmin32( frcmax32( round(width*0.80), round(450*vizoom*vifontwidthratio)), 32*vizoom);//21apr2025
xlinelimit:=frcmin32(xmaxwidth div frcmin32(resfont__wave(vinormal.Rfn),5) , 5);

//parse lines
lparse;

//timer
ihintOnsecs:=frcmin32(ihintlines.count*5,5);
except;end;
end;

