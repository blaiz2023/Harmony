      end;

   end;

//.from screen
if not xfrombufferOK then
   begin

   a   :=miswin32(1,1);
   if low__cap2432(xpos,ypos,1,1,a) then result:=rgba0__int(a.prows32[0][0].r,a.prows32[0][0].g,a.prows32[0][0].b);

   end;

skipend:
except;end;
//free
freeobj(@a);
end;

