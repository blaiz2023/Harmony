procedure vimoderncolors(var x:tclientinfo);//05jun2025: line2, 04jun2025, 26may2025: tweaked
var
   vlum,v:longint;
begin
//background -------------------------------------------------------------------
v   :=x.back;
vlum:=c24__lum(int__c24(v));


case vlum of
0..50:begin//adjust for very dark background
   x.row           :=int__dif242(v,10,false);
   x.hint          :=int__dif242(v,20,false);
   x.hover         :=int__dif242(v,35,false);
   x.hover2        :=int__dif242(v,60,false);
   x.line          :=int__dif242(v,40,false);
   x.line2         :=int__dif242(v,100,false);
   x.sep           :=int__dif242(v,13+insint(8,vlum<=30),false);//04jun2025: increased to 8 from 6
   x.border        :=v;
   x.mustborder    :=int__dif242(v,20,false);//for controls that must display a border, e.g. some tbasicedit
   end;
235..255:begin//adjust for very light background
   x.row           :=int__dif242(v,-5,false);
   x.hint          :=int__dif242(v,-10,false);
   x.hover         :=int__dif242(v,-15,false);
   x.hover2        :=int__dif242(v,-25,false);
   x.line          :=int__dif242(v,-20,false);
   x.line2         :=int__dif242(v,-60,false);
   x.sep           :=int__dif242(v,-16,false);
   x.border        :=v;
   x.mustborder    :=int__dif242(v,-10,false);//for controls that must display a border, e.g. some tbasicedit
   end;
else
   begin//normal operation
   x.row           :=int__dif242(v,5,false);
   x.hint          :=int__dif242(v,10,false);
   x.hover         :=int__dif242(v,20,false);
   x.hover2        :=int__dif242(v,30,false);
   x.line          :=int__dif242(v,18,false);
   x.line2         :=int__dif242(v,38,false);//05jun2025
   x.sep           :=int__dif242(v,10,false);
   x.border        :=v;
   x.mustborder    :=int__dif242(v,10,false);//for controls that must display a border, e.g. some tbasicedit
   end;
end;//case

//color highlight  -------------------------------------------------------------

x.colhover :=int__splice24(0.5,x.hover,x.colhover);
v          :=x.colhover;

case int__lum(v) of
0..160:x.colfont:=int__dif242(v,80,false);
else   x.colfont:=int__dif242(v,-80,false);
end;//case


case int__lum(x.back) of
160..255:begin

   x.colhover2.x:=int__splice24(0.15,x.colhover,0);//0.15 for reasonable contrast - 13sep2025
   x.colhover2.y:=x.colhover;

   end;
else
   begin

   x.colhover2.x:=x.back;
   x.colhover2.y:=x.colhover;

   end;
end;//case

end;

