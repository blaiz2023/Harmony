   begin
   playlist__getone('',ilistcoreFULL,p,xsec,xtitle,xfilename);
   playlist__addone('',a,xsec,xtitle,xfilename,ipartmask);
   end;//p
   //set
   ilistcore.clear;
   ilistcore.add(a);//all in one go
   //.inc id
   low__iroll(ilistcoreid,1);
   //.sync with host list
   xlistsync;
   end;
except;end;

//free
str__free(@a);

end;

