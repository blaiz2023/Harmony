procedure sysback__init;//19aug2025, 08mar2025
var
   xlimit,p:longint;
   xcanwrite:boolean;

   function xscreenHeight:longint;
   begin
   result:=monitors__screenheight_auto;
   end;

   function xscreenWidth:longint;
   begin
   result:=monitors__screenwidth_auto;
   end;

   procedure xnew2(const xname:string;const xiscustom:boolean;const xfromfile,xmakename:string;const xfromarray:array of byte);
   begin

   if (sysback_count<xlimit) and xcanwrite then
      begin

      if (xname<>'') then
         begin

         //clear
         sysback__clear(sysback_count);

         //get
         sysback_name[sysback_count]          :=xname;
         sysback_iscustom[sysback_count]      :=xiscustom;
         sysback_datafromfile[sysback_count]  :=xfromfile;
         sysback_makename[sysback_count]      :=xmakename;
         sysback_datafromptr[sysback_count]   :=low__maplist(xfromarray);
         inc(sysback_count);

         end;

      end
   else xcanwrite:=false;//stop writing

   end;

   procedure xnew(const xname:string;const xiscustom:boolean;const xfromfile:string;const xfromarray:array of byte);
   begin

   xnew2(xname,xiscustom,xfromfile,'',xfromarray);

   end;

   procedure s(xnameid,xindex,xval:longint;xcanchange:boolean);
   begin

   if not xcanwrite then exit;

   sysback__setval2(xnameid,xindex,xval,true);

   //.store defaults
   case xnameid of
   bkmStrength  :sysback_strengthDEF[xindex]  :=sysback_strength[xindex];
   bkmColorise  :sysback_coloriseDEF[xindex]  :=sysback_colorise[xindex];
   bkmSpeed     :sysback_speedDEF[xindex]     :=sysback_speed[xindex];
   bkmHstep     :sysback_hstepDEF[xindex]     :=sysback_hstep[xindex];
   bkmVstep     :sysback_vstepDEF[xindex]     :=sysback_vstep[xindex];
   bkmFstep     :sysback_fstepDEF[xindex]     :=sysback_fstep[xindex];
   bkmHwobble   :sysback_hwobbleDEF[xindex]   :=sysback_hwobble[xindex];
   bkmVwobble   :sysback_vwobbleDEF[xindex]   :=sysback_vwobble[xindex];
   bkmFwobble   :sysback_fwobbleDEF[xindex]   :=sysback_fwobble[xindex];
   bkmCrate     :sysback_crateDEF[xindex]     :=sysback_crate[xindex];
   end;//case


   if xcanchange then
      begin
      case xnameid of
      bkmStrength  :sysback_canstrength[xindex]  :=xcanchange;
      bkmColorise  :sysback_cancolorise[xindex]  :=xcanchange;
      bkmSpeed     :sysback_canspeed[xindex]     :=xcanchange;
      bkmHstep     :sysback_canhstep[xindex]     :=xcanchange;
      bkmVstep     :sysback_canvstep[xindex]     :=xcanchange;
      bkmFstep     :sysback_canfstep[xindex]     :=xcanchange;
      bkmHwobble   :sysback_canhwobble[xindex]   :=xcanchange;
      bkmVwobble   :sysback_canvwobble[xindex]   :=xcanchange;
      bkmFwobble   :sysback_canfwobble[xindex]   :=xcanchange;
      bkmCrate     :sysback_cancrate[xindex]     :=xcanchange;
      end;//case

      sysback_canadjust[xindex]                  :=true;
      end;

   end;

   procedure s0(xnameid,xval:longint);//set value and but disable any user alterations
   begin
   s(xnameid,sysback_count-1,xval,false);
   end;

   procedure s1(xnameid,xval:longint);//set value and enable
   begin
   s(xnameid,sysback_count-1,xval,true);
   end;

   procedure sall;
   begin
   s1(bkmStrength,0);
   s1(bkmColorise,0);
   s1(bkmSpeed,0);
   s1(bkmHstep,0);
   s1(bkmVstep,0);
   s1(bkmFstep,0);
   s1(bkmHwobble,0);
   s1(bkmVwobble,0);
   s1(bkmFwobble,0);
   end;

   procedure xnewfull(const xname:string;const xfromarray:array of byte);
   begin

   xnew(xname,false,'',xfromarray);
   sall;
   s1(bkmStrength,55);
   s0(bkmColorise,-100);
   s1(bkmSpeed,frcmax32(20,background_speed_limit));//07jan2026, 30dec2025
   s1(bkmVstep,1);
   s1(bkmHstep,1);

   end;

   procedure pnew(const xname,xmakename:string);
   begin

   xnew2(xname,false,'',xmakename+';',back_none);

   end;

   procedure pGradient(const xname:string;const r,g,b:byte);
   var//w=width, h=height, k=background color(0..N, -1=transparent, -2=not used), a-d=color1..4, s=splice100(0..100), p=power255(0..255),
      hratio,hratio2:double;
      dcol,p:longint;
      dlabel,dname,v:string;
   begin

   dcol     :=rgba0__int(r,g,b);

   for p:=0 to 3 do
   begin

   case p of

   0:begin

      v               :=' (Static)';
      hratio          :=1.0;
      hratio2         :=1.0;

      end;

   1:begin

      v:=' (Fade)';
      hratio          :=1.0;
      hratio2         :=1.0;

      end;

   2:begin

      v:=' (Scrolling)';
      hratio          :=1.5;
      hratio2         :=1.0;

      end;

   3:begin

      v:=' (Scrolling-Narrow)';
      hratio          :=1.5;
      hratio2         :=0.5;

      end;

   else
      begin

      v:='';
      hratio:=1.0;

      end;

   end;//case

   pnew('Gradient'+insstr(#32,xname<>'')+xname+v,'!gradient;w2;h'+intstr32(round32(xscreenHeight*hratio))+';j'+intstr32(round32(xscreenHeight*hratio2))+';k0;a0;b'+intstr32(dcol)+';c'+intstr32(dcol)+';d0;p255;s50');//full gradient does not required a background color "k-2"

   //.remake tile when screen changes
   if (sysback_count<xlimit) then
      begin

      sysback_remakeonScreen[sysback_count-1] :=true;

      end;

   s1(bkmStrength,60);

   case (r=255) and (g=255) and (b=255) of
   true:s0(bkmColorise,-100);//system
   else s0(bkmColorise,100);//color
   end;//case

   //.speed
   case p of
   1..3:s1(bkmSpeed,18);
   end;

   //.fstep
   case p of
   1..3:s1(bkmFstep,2);
   end;

   //.vstep
   case p of
   2..3:s1(bkmVstep,5);
   end;

   end;//p

   end;

   procedure pVLine(const xname:string;const r,g,b:byte);
   var//w=width, h=height, k=background color(0..N, -1=transparent, -2=not used), a-d=color1..4, s=splice100(0..100), p=power255(0..255),
      dcol,p:longint;
      dlabel,dname,v:string;
   begin

   dcol     :=rgba0__int(r,g,b);

   for p:=1 to 2 do
   begin

   case p of
   2    :v:=' (Strobe)';
   else  v:='';
   end;//case

   pnew('Gradient-Line'+insstr(#32,xname<>'')+xname+v,'!v-line;w'+intstr32(xscreenWidth)+';h2;k-1;a'+intstr32(int__splice24(0.35,0,dcol))+';b'+intstr32(dcol)+';c'+intstr32(dcol)+';d'+intstr32(int__splice24(0.35,0,dcol))+';p255;s50');//full gradient does not required a background color "k-1"

   //.remake tile when "viscale" changes
   if (sysback_count<xlimit) then
      begin

      sysback_remakeonScreen[sysback_count-1] :=true;
      sysback_remakeonScale[sysback_count-1]  :=true;

      end;

   case p of
   1:s1(bkmStrength,40);//no strobe
   2:s1(bkmStrength,45);//with strobe
   end;//case

   case (r=255) and (g=255) and (b=255) of
   true:s0(bkmColorise,-100);//system
   else s0(bkmColorise,100);//color
   end;//case

   //.speed
   case p of
   1..2:s1(bkmSpeed,18);
   end;

   //.fstep
   case p of
   2..2:s1(bkmFstep,6);
   end;

   //.hstep
   case p of
   1..2:s1(bkmHstep,3);
   end;

   end;//p

   end;

   procedure pMake(const xtype:longint32;const xname:string;const r,g,b:byte);
   begin

   case xtype of
   0:pGradient(xname,r,g,b);
   1:pVLine(xname,r,g,b);
   end;//case

   end;

   function pRandomColor(const xtype:longint):boolean;
   var
      vlabel:string;
   begin

   //init
   result:=(xtype>=0) and (xtype<=3);
   if not result then exit;

   //0=random color
   //1=random color + strobe
   //2=random color + system
   //3=random color + system/strobe

   case xtype of
   1   :vlabel:=' (Fade)';
   2   :vlabel:=' (System)';
   3   :vlabel:=' (System-Fade)';
   else vlabel:='';
   end;//case

   pnew('Random Color'+vlabel,'!random-color;w10;h10;k-1;');

   //.remake always
   if (sysback_count<xlimit) then
      begin

      sysback_remakeonScreen[sysback_count-1] :=true;
      sysback_remakeonCrate[sysback_count-1]  :=true;

      end;

   s1(bkmStrength,40);

   case xtype of
   2..3:s0(bkmColorise,-100);
   else s0(bkmColorise,100);
   end;//case

   s1(bkmSpeed,5);
   s1(bkmCrate,2);

   case xtype of
   1,3:s1(bkmFstep,10);
   end;//case

   end;

begin
//check
if (sysback_count<>0) then exit;

//init
xlimit    :=high(sysback_name);
xcanwrite :=true;

//built-in
xnew('Default',false,'',back_none);
xnew('None',false,'',back_none);

//.fuzz
xnewfull('Fuzz',back_fuzz);

xnew('Fuzz 2',false,'',back_fuzz);
sall;
s0(bkmStrength,50);
s0(bkmColorise,-100);
s1(bkmSpeed,20);
s1(bkmVstep,1);
s1(bkmFstep,10);

