procedure tbasiccolor.xdomenu(xcode2:string);
var
   a:tint4;
   c:tdynamicstring;
   z:string;
begin
try
//defaults
c:=nil;
//get
if      (xcode2='paste') then
   begin
{//no support yet
   if clip__hasformat(cf_bitmap) then
      begin
      b:=ccs.newbmp(1,1);
      b.assign(clipboard);
      if ccs.valid24(b) then color:=ccs.pixels[b,0,0];
      end
{}
   if clip__hasformat(cf_text) then
      begin
      //get
      z:=clip__pastetextb;
      z:=low__firstline(z);
      //decide
      //.hex -> accepts #fff / fff / #fffa / fffa / #ffffff / ffffff - mixture of 24bit and 32bit hex colors with or without leading hash - 17nov2023
      if (strcopy1(z,1,1)='#') then color:=hex8__int(z,255,rgba__int(127,127,127,255))
      //.rgb
      else if (low__findchar(z,',')>=1) then
         begin
         //init
         c:=tdynamicstring.create;
         swapchars(z,',',#10);
         c.text:=z;
         if (c.count>=4) and iuse32 then
            begin
            a.r:=frcrange32(strint32(c.value[0]),0,255);
            a.g:=frcrange32(strint32(c.value[1]),0,255);
            a.b:=frcrange32(strint32(c.value[2]),0,255);
            a.a:=frcrange32(strint32(c.value[3]),0,255);
            color:=a.val;
            end
         else
            begin
            c.text:=z+rcode+'0'+rcode+'0'+rcode+'0'+rcode+'0';
            a.r:=frcrange32(strint32(c.value[0]),0,255);
            a.g:=frcrange32(strint32(c.value[1]),0,255);
            a.b:=frcrange32(strint32(c.value[2]),0,255);
            color24:=a.val;
            end;
         end
      //.number
      else
         begin
         case iuse32 of
         true:color:=strint32(z);
         else color24:=frcmin32(strint32(z),0);
         end;
         end;
      end;
   end
//was:
else if (xcode2='copyhex') then
   begin
   case iuse32 of
   true:clip__copytext(int__hex8(icolor,true));
   else clip__copytext(int__hex6(icolor,true));
   end;
   end
else if (xcode2='copyrgb') then
   begin
   a.val:=icolor;
   case iuse32 of
   true:clip__copytext(intstr32(a.r)+','+intstr32(a.g)+','+intstr32(a.b)+','+intstr32(a.a));
   else clip__copytext(intstr32(a.r)+','+intstr32(a.g)+','+intstr32(a.b));
   end;//case
   end
else if (xcode2='copynum') then clip__copytext(intstr32(icolor))
else if (xcode2='copypix') then
   begin
//Windows only:
{
   if (oscode=oswindows) then
      begin
      b:=low__newbmp24CLS(1,1,icolor);
      clip__copyimage(b);
      end;
{}//xxxxxxxxxxx

   end
else if (xcode2='invert') then color24:=int__invertb(color);
except;end;
//free
freeobj(@c);
end;

function tbasiccolor.xshadecolor24:longint;//03feb2024
var
   a:tpoint;
   w,i:longint;
begin
if validarea(ishadearea) and (ishadelist.count>=1) then
   begin
   //read color value directly from the shade list -> palette still functions even if global color grab "low__capcolor()" proc fails - 03feb2025
   a.x:=mousemovexy.x;
   a.y:=mousemovexy.y;
   if (a.x>=ishadearea.left) and (a.x<=ishadearea.right) and (a.y>=ishadearea.top) and (a.y<=ishadearea.bottom) then
      begin
      w:=frcmin32(ishadearea.right-ishadearea.left+1,1);
      i:=frcrange32( round(((a.x-ishadearea.left)/w)*ishadelist.count),0,ishadelist.count-1);
      result:=ishadelist.value[i];
      end
   else result:=low__capcolor(0,0,true);
   end
else result:=low__capcolor(0,0,true);
end;

procedure tbasiccolor._onpaint(sender:tobject);
const
   sp=2;
var
   s:tclientinfo;
   tw,tc,pcount,xcolor,xshadecolor,int1,dx:longint;
   a1,a2:twinrect;
   c32:tcolor32;

   procedure pdraw(sc,dc:longint);
   var
      c,ppert,p:longint;
   begin

   //range
   if (pcount<1) then pcount:=1;

   //get
   for p:=1 to pcount do
   begin

   ppert    :=frcrange32(round((p*100)/pcount),0,100);

   c        :=int__splice24_100(ppert,sc,dc);

   ffillarea( area__make( dx ,a2.top ,dx ,a2.bottom ) ,c ,false );

   ishadelist.value[dx-s.ci.left]:=c;

   inc(dx);
   if (dx>s.ci.right) then break;

   end;//p

   end;

begin
try

//init
infovars(s);
xcolor      :=icolor;
xshadecolor :=ishadecolor;

//apply alpha when use32=true - 17nov2023
if iuse32 then
   begin

   c32      :=int__c32(xcolor);
   xcolor   :=int__splice24((255-c32.a)/255,rgba0__int(c32.r,c32.g,c32.b),int_255_255_255);

   end;

//cls
if oshaderange then
   begin

   //init
   int1               :=((s.ci.bottom-s.ci.top+1) div 2);
   a1                 :=s.ci;
   a1.bottom          :=a1.top+int1;
   a2                 :=s.ci;
   a2.top             :=a1.bottom+1;
   a2.bottom          :=s.ci.bottom;

   pcount             :=frcmin32(s.ci.left+((s.ci.right-s.ci.left+1) div 4),1);
   ishadearea         :=area__make(s.ci.left+2,a2.top,s.ci.right-2,s.ci.bottom-1);

   ishadelist.clear;//cache shade colors for direct color grab - 03feb2025

   //actual color
   ffillArea(a1,xcolor,false);

   //shade ranges
   dx                 :=s.ci.left;

   pdraw(0,xshadecolor);
   pdraw(xshadecolor,int_255_255_255);
   pdraw(int_255_255_255,int__invertb(xshadecolor));
   pdraw(int__invertb(xshadecolor),0);

   end
else
   begin

   ffillArea(s.ci,xcolor,s.r);

   end;

//caption - 24oct2025
if (caption<>'') then
   begin

   tc       :=int__colorlabel(xcolor);
   tw       :=fast__textwidth('',caption,s.Rfn);
   ftext(s.back,s.cs,s.cs.left + ((s.cw-tw) div 2), s.cs.top + ((s.ch-s.fnH) div 2), tc, '',caption,s.Rfn ,true);

   end;

//frame
xframeSimple( s );

except;end;
end;


