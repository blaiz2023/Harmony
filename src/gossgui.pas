procedure tbasictea.makeimagetrans(const xtrans:boolean;const xstyle:longint);
label
   skipend;

var
   a:tbasicimage;
   b:tstr8;
   e:string;
begin

//defaults
a           :=nil;
b           :=nil;
e           :=gecTaskfailed;

//check
if not canmakeimagetrans then exit;

//init
a           :=misimg32(1,1);
b           :=str__new8;

//get
if not mis__fromdata(a,@idata,e) then goto skipend;

case xtrans of

true:begin

   if not mask__hastransparency32( a ) then
       begin

       case xstyle of
       1   :mask__makesimple0255( a ,mispixel24val(a,mish(a)-1,0) );//bottom-left
       else mask__makesimple0255( a ,mispixel24val(a,0,0) );//top-left
       end;//case

       mis__todata( a,@b,'tea',e);
       xundoFill;
       setdata(b);

       end;

   end;

else begin

   if mask__hastransparency32( a ) then
       begin

       mask__setval( a ,255 );
       mis__todata( a,@b,'tea',e);
       xundoFill;
       setdata(b);

       end;
   end;

end;//case

//successful
e           :='';
skipend:

//free
freeobj(@a);
str__free(@b);

//show error
if (e<>'') then gui.poperror('',e);

end;

procedure tbasictea.openimage;
label
   skipend;

var
   a:tbasicimage;
   b:tstr8;
   e:string;

begin

//defaults
a           :=nil;
b           :=nil;
e           :=gecTaskfailed;

try

//get

if gui.popopenimg(sysfolder_imagefilename,sysfolder_imageopenfilter,'') then
   begin

   //get
   a        :=misimg32(1,1);
   b        :=str__new8;

   if not mis__fromfile(a,sysfolder_imagefilename,e)   then goto skipend;
   if not mis__todata(a,@b,'bmp',e)                    then goto skipend;//bmp is faster than png for large, detailed images

   //set
   xundoFill;
   setdata(b);

   end
else begin

  //re-instate the image for "tepTEMP20" as it can be modified by a call to "popopen()->changefolderimage()" - 23mar2026
  setdata(idata);

  end;

//successful
e           :='';
skipend:

except;end;

//free
freeobj(@a);
str__free(@b);

//show error
if (e<>'') then gui.poperror('',e);

end;

