function tbasicmenu.vcount:longint;//visible count
begin
result:=frcmin32((frcmin32(clientheight,1)-(2*frcmin32(findbordersize,0))) div xrowheight,1);
end;

function tbasicmenu.vpos1:longint;//first visible item
begin
