debug_mstimetotal  :=debug_mstimetotal+(debug_msstop-debug_msstart);
debug_mstimecount  :=debug_mstimecount+1;

//.avefast
debug_mstimetotal2 :=debug_mstimetotal2+(debug_msstop-debug_msstart);
