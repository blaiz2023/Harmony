procedure tbasicsplash.xmaketitle(dw,dh:longint);//scaling support - 18mar2026, 11dec2025, 13sep2025: lighter memory usage when "fontfeatherf>=1", 08apr2025: improved for short titles
label
   skipend;
var
   xlast:pfastdraw;
   l:tresslot;
   f:tresslot;
   s:tclientinfo;
   sr32:pcolorrow32;
   f24:tcolor24;
   s32:tcolor32;
   a:tbasicimage;//pointer only
   v,sx,sy,bw,bh,aw,ah,fW,fH,sw,sh:longint;
   xname:string;
   bol1:boolean;
   b:tbasicimage;
   busedarea:twinrect;
begin

//defaults
b           :=nil;
l           :=res_nil;
f           :=res_nil;

//check
if not misok32(ititle32,sw,sh) then exit;

//name
xname:=app__info('name');
if not low__setstr(ititleref,intstr32(sw)+'|'+intstr32(sh)+'|'+xname) then exit;

try
//init

fd__selStore(xlast);
l           :=res__newFastdraw;//use a new dedicated fastdraw slot/record - 28feb2026
fd__select(l);
fd__defaults;

iscreen.infovars(s);

a           :=ititle32;
f           :=res__newfont;
res__font(f).setparams( 'arial' ,scale__px1(68,7) ,true ,true ,false );//18mar2026 - bold
fW          :=frcmin32(resfont__textwidth(f,xname),400);//for short names enforce a minimum width of 400px - 11dec2025, 08apr2025
fH          :=resfont__height(f);
f24         :=int__c24(s.font);

//get
missize(a,2+fW,2+fH);
aw          :=misw(a);
ah          :=mish(a);
miscls(a,0);

fd__setbuffer( fd_buffer ,a );
fast__drawText( clnone ,misarea(a) ,misarea(a) ,1 ,1 ,rgba__int(255,255,255,255) ,'' ,xname ,f ,cdNone ,viFeather );

//.create a 300-400% buffer a24b to enlarge the text in buffer a24 for upscaling/blurring
b           :=misimg32(3*misw(a),3*mish(a));//using font based feathering required less upscaling/blurring - 13sep2025
bw          :=misw(b);
bh          :=mish(b);

//.copy TEXT image a onto b
if not mis__copyfast(maxarea,misarea(a),0,0,misw(b),mish(b),a,b) then goto skipend;


//.blur the enlarged TEXT to generate a finer quality text outline
misblur82432(b);

//.find used area
busedarea.left        :=bw-1;
busedarea.right       :=0;
busedarea.top         :=bh-1;
busedarea.bottom      :=0;

for sy:=0 to (bh-1) do
begin

if not misscan32(b,sy,sr32) then goto skipend;

bol1        :=false;

for sx:=0 to (bw-1) do
begin

s32         :=sr32[sx];
v           :=s32.r;
if (s32.g>v) then v:=s32.g;
if (s32.b>v) then v:=s32.b;

if (v>=1) then
   begin

   if (sx<busedarea.left)      then busedarea.left:=sx;
   bol1:=true;

   end;

end;//sx

if bol1 then
   begin

   if (sy<busedarea.top)       then busedarea.top:=sy;
   if (sy>busedarea.bottom)    then busedarea.bottom:=sy;

   end;

end;//dy

//.use to the right hand margin
busedarea.right       :=bw-1;

//.shrink draw b buffer back onto a buffer
missize(a,dw,dh);

aw                    :=misw(a);
ah                    :=mish(a);

if not mis__copyfast(maxarea,busedarea,0,0,misw(a),mish(a),b,a) then goto skipend;

//.make mask based on b32.r/g/b
for sy:=0 to (ah-1) do
begin

if not misscan32(a,sy,sr32) then goto skipend;

for sx:=0 to (aw-1) do
begin

s32         :=sr32[sx];
v           :=s32.r;
if (s32.g>v) then v:=s32.g;
if (s32.b>v) then v:=s32.b;
s32.a       :=v;

if (v=255) then
   begin

   s32.r    :=f24.r;
   s32.g    :=f24.g;
   s32.b    :=f24.b;

   end
else if (v>=1) then
   begin

   s32.r    :=( (f24.r*v) + ((255-v)*91) ) div 256;
   s32.g    :=( (f24.g*v) + ((255-v)*91) ) div 256;
   s32.b    :=( (f24.b*v) + ((255-v)*91) ) div 256;

   end;

sr32[sx]    :=s32;

end;//sx

end;//dy

skipend:
except;end;

//free
freeobj(@b);
res__del( f );
fd__selRestore(xlast);
res__del( l );

end;

