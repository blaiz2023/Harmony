procedure tbasichelp.settext(x:string);//14may2025

   function xformat:string;
   var
      xfirst:boolean;
      xlen,p:longint;
      c:char;

      function f(xpos:longint):char;
      begin

      if (xpos>=1) and (xpos<=xlen) then result:=x[xpos-1+stroffset] else result:=#0;

      end;

      procedure a(x:char);
      begin

      result:=result+x;

      end;

   begin

   //defaults
   result   :='';
   xlen     :=low__len32(x);
   xfirst   :=true;

   //get
   for p:=1 to low__len32(x) do
   begin

   c        :=x[p-1+stroffset];

   if (c='|') and (xfirst or ((f(p-1)<>#32) and (f(p+1)<>#32))) then
      begin

      if xfirst then
         begin

         a(#32);
         a('-');
         a(#32);

         end

      else a(#32);

      xfirst:=false;

      end

   else a(c);

   end;//p

   end;
begin

//filter
if (x='') then x:=ideftext;

//get
if (x<>itextref) then
   begin

   //set
   itextref :=x;
   itext    :=xformat;

   low__iroll(itextid,1);//id

   //reset
   ipostime :=slowms64+2000;
   ipos     :=1;

   paintnow;

   end;

end;

